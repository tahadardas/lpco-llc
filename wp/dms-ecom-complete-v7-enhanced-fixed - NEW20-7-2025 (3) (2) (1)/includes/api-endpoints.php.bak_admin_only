// BRANDS ENDPOINT
// ============================================================================

/**
 * Get product brands (from tags or attributes)
 */
function dms_get_brands($request) {
    $per_page = $request->get_param('per_page') ?: 50;
    $page = $request->get_param('page') ?: 1;
    
    // Try to get brands from product_brand taxonomy first
    $args = array(
        'taxonomy' => 'product_brand',
        'hide_empty' => true,
        'number' => $per_page,
        'offset' => ($page - 1) * $per_page,
        'update_term_meta_cache' => true,
        'orderby' => 'name',
        'order' => 'ASC'
    );
    
    $brands = get_terms($args);
    
    // If no product_brand taxonomy, try tags
    if (empty($brands) || is_wp_error($brands)) {
        $args['taxonomy'] = 'product_tag';
        $brands = get_terms($args);
    }
    
    if (is_wp_error($brands) || empty($brands)) {
        return array();
    }
    
    $payload = array_map(function($brand) {
        $image_url = dms_ecom_resolve_brand_image_url($brand);

        return array(
            'id' => $brand->term_id,
            'name' => $brand->name,
            'slug' => $brand->slug,
            'count' => $brand->count,
            'image_url' => $image_url
        );
    }, $brands);
    dms_send_cache_headers('brands_legacy_' . md5(wp_json_encode($payload)));
    return $payload;
}

