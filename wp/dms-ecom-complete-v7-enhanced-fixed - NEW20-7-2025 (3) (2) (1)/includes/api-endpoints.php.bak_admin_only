/**
 * Default group/currency for guest browsing
 */
function dms_ecom_guest_defaults() {
    $settings = function_exists('dms_app_get_settings') ? dms_app_get_settings() : array();
    $group = !empty($settings['default_group']) ? sanitize_text_field($settings['default_group']) : 'default';
    $currency = !empty($settings['default_currency']) ? sanitize_text_field($settings['default_currency']) : 'syp';
    return array($group, $currency);
}

/**
 * Guest products endpoint (reuses main formatter)
 */
function dms_get_products_guest($request) {
    // Ensure no user context is leaked
    wp_set_current_user(0);
    list($group, $currency) = dms_ecom_guest_defaults();
    
    // Allow overriding currency/group via query for flexibility
    if (!$request->get_param('user_group')) {
        $request->set_param('user_group', $group);
    }
    if (!$request->get_param('currency')) {
        $request->set_param('currency', $currency);
    }
    if (!$request->get_param('guest') && !$request->get_param('mode')) {
        $request->set_param('guest', 1);
    }
    
    return dms_get_products_with_prices($request);
}

/**
 * Guest categories endpoint with thumbnails
 */
function dms_ecom_is_truthy_meta_value($value) {
    if (is_bool($value)) {
        return $value;
    }

    if (is_numeric($value)) {
        return floatval($value) > 0;
    }

    $normalized = strtolower(trim((string) $value));
    if ($normalized === '') {
        return false;
    }

    return in_array($normalized, array(
        '1',
        'true',
        'yes',
        'on',
        'hide',
        'hidden',
        'private'
    ), true);
}

function dms_ecom_is_hidden_term_for_app($term, $taxonomy = 'product_cat') {
    $term_id = 0;
    if ($term instanceof WP_Term) {
        $term_id = (int) $term->term_id;
        if (!empty($term->taxonomy)) {
            $taxonomy = (string) $term->taxonomy;
        }
    } elseif (is_object($term) && isset($term->term_id)) {
        $term_id = (int) $term->term_id;
    } elseif (is_array($term) && isset($term['term_id'])) {
        $term_id = (int) $term['term_id'];
    } else {
        $term_id = (int) $term;
    }

    if ($term_id <= 0) {
        return false;
    }

    $is_hidden = false;
    $all_meta = dms_ecom_get_all_term_meta($term_id);

    $hide_meta_keys = array(
        'dms_hide_in_app',
        'lpco_hide_in_app',
        'hide_in_app',
        'is_hidden',
        'hidden',
        'dms_hidden',
        'lpco_hidden',
        'app_hidden',
        'dms_app_hidden',
    );
    foreach ($hide_meta_keys as $meta_key) {
        $meta_value = $all_meta[$meta_key][0] ?? '';
        if (dms_ecom_is_truthy_meta_value($meta_value)) {
            $is_hidden = true;
            break;
        }
    }

    if (!$is_hidden) {
        $visibility_meta_keys = array(
            'visibility',
            'app_visibility',
            'dms_visibility',
        );
        foreach ($visibility_meta_keys as $meta_key) {
            $meta_value = strtolower(trim((string) ($all_meta[$meta_key][0] ?? '')));
            if (in_array($meta_value, array('hidden', 'private', 'none', 'disabled', 'off', '0', 'false', 'no'), true)) {
                $is_hidden = true;
                break;
            }
        }
    }

    if (!$is_hidden) {
        $show_meta_keys = array(
            'show_in_app',
            'lpco_show_in_app',
            'dms_show_in_app',
        );
        foreach ($show_meta_keys as $meta_key) {
            if (!array_key_exists($meta_key, $all_meta)) {
                continue;
            }
            $meta_value = $all_meta[$meta_key][0] ?? '';
            if (!dms_ecom_is_truthy_meta_value($meta_value)) {
                $is_hidden = true;
                break;
            }
        }
    }

    return (bool) apply_filters(
        'dms_ecom_is_hidden_term_for_app',
        $is_hidden,
        $term,
        $taxonomy
    );
}

function dms_format_category_term($term) {
    if (dms_ecom_is_hidden_term_for_app($term, 'product_cat')) {
        return null;
    }

    $thumb_id = dms_ecom_get_term_meta_value($term->term_id, 'thumbnail_id');
    $image_url = $thumb_id ? dms_ecom_get_attachment_url_cached($thumb_id) : '';
    $count = (int) $term->count;
    if ($count <= 0) {
        return null;
    }

    return array(
        'id' => (int) $term->term_id,
        'name' => $term->name,
        'slug' => $term->slug,
        'description' => $term->description,
        'count' => $count,
        'image_url' => $image_url,
        'parent' => (int) $term->parent,
        'taxonomy' => $term->taxonomy
    );
}

function dms_get_categories_base($request) {
    // توحيد الاستعلام بين الضيف والمستخدم: نفس الاستعلام تماماً
    $is_guest = lpco_dms_is_guest_request($request);
    $cache_key = '';
    if ($is_guest) {
        $cache_key = lpco_dms_guest_cache_key('categories', $request);
        $cached = lpco_dms_guest_cache_get($cache_key);
        if ($cached !== false) {
            return $cached;
        }
    }
    $args = array(
        'taxonomy'   => 'product_cat',
        'hide_empty' => true,
        'pad_counts' => true,
        'update_term_meta_cache' => true,
        'orderby'    => 'menu_order',
        'order'      => 'ASC',
        'number'     => 0, // جميع التصنيفات
        'offset'     => 0
    );

    $terms = get_terms($args);
    
    if (is_wp_error($terms)) {
        return $terms;
    }

    $attachment_ids = array();
    foreach ($terms as $term) {
        $thumb_id = absint(dms_ecom_get_term_meta_value($term->term_id, 'thumbnail_id'));
        if ($thumb_id > 0) {
            $attachment_ids[$thumb_id] = $thumb_id;
        }
    }
    dms_ecom_prime_attachment_ids($attachment_ids);
    
    $categories = array();
    foreach ($terms as $term) {
        $formatted = dms_format_category_term($term);
        if ($formatted) {
            $categories[] = $formatted;
        }
    }
    // Apply custom ordering when configured
    if (function_exists('lpco_app_layout_config_get') && function_exists('lpco_app_layout_apply_order')) {
        $config = lpco_app_layout_config_get();
        if (!empty($config['categories'])) {
            $categories = lpco_app_layout_apply_order($categories, $config['categories'], 'id');
        }
    }
    // Re-index
    $categories = array_values($categories);
    if ($is_guest && $cache_key) {
        lpco_dms_guest_cache_set($cache_key, $categories);
    }
    return $categories;
}

function dms_get_categories_guest($request) {
    // Ensure we don't leak auth context
    wp_set_current_user(0);
    if (!$request->get_param('guest') && !$request->get_param('mode')) {
        $request->set_param('guest', 1);
    }
    $categories = dms_get_categories_base($request);
    if (!is_wp_error($categories)) {
        dms_send_cache_headers('categories_guest_' . md5(wp_json_encode($categories)));
    }
    return $categories;
}

function dms_get_categories_auth($request) {
    $categories = dms_get_categories_base($request);
    if (!is_wp_error($categories)) {
        dms_send_cache_headers('categories_auth_' . md5(wp_json_encode($categories)));
    }
    return $categories;
}

/**
 * Home endpoint: products grouped by category order
 */
function dms_home_by_category($request) {
    // إذا لم يُمرر حد، نجلب كل المنتجات في التصنيف
    $per_category = intval($request->get_param('per_category'));
    if ($per_category <= 0) {
        $per_category = -1; // كل المنتجات
    }

    $is_guest = lpco_dms_is_guest_request($request);
    list($current_user_id, $current_group, $current_currency) = dms_ecom_get_request_user_context($request, $is_guest);
    $cache_key = $is_guest
        ? lpco_dms_guest_cache_key('home_by_category', $request)
        : lpco_dms_auth_cache_key('home_by_category', $request, $current_user_id, $current_group, $current_currency);
    $cached = $is_guest ? lpco_dms_guest_cache_get($cache_key) : lpco_dms_auth_cache_get($cache_key);
    if ($cached !== false) {
        dms_send_cache_headers('home_by_category_' . md5(wp_json_encode($cached)));
        return $cached;
    }
    
    // Fetch categories using unified source
    $categories = dms_get_categories_base($request);
    if (is_wp_error($categories)) {
        return $categories;
    }
    
    if (empty($categories)) {
        return array('categories' => array());
    }

    $prod_request = new WP_REST_Request('GET', '/dms/v1/products');
    $prod_request->set_param('per_page', -1);
    $prod_request->set_param('page', 1);
    $prod_request->set_param('stock_order', 'in_first');
    if ($is_guest) {
        $prod_request->set_param('guest', 1);
    }
    if ($request->get_param('user_group')) {
        $prod_request->set_param('user_group', $request->get_param('user_group'));
    }
    if ($request->get_param('currency')) {
        $prod_request->set_param('currency', $request->get_param('currency'));
    }

    $all_products = dms_get_products_with_prices($prod_request);
    if (is_wp_error($all_products)) {
        $all_products = array();
    }

    $products_by_cat = array();
    foreach ($all_products as $product) {
        if (empty($product['categories']) || !is_array($product['categories'])) {
            continue;
        }
        foreach ($product['categories'] as $category_item) {
            $category_id = isset($category_item['id']) ? (int) $category_item['id'] : 0;
            if ($category_id <= 0) {
                continue;
            }
            if (!isset($products_by_cat[$category_id])) {
                $products_by_cat[$category_id] = array();
            }
            $products_by_cat[$category_id][] = $product;
        }
    }

    $response = array();
    foreach ($categories as $cat) {
        $category_products = $products_by_cat[$cat['id']] ?? array();
        if ($per_category > 0) {
            $category_products = array_slice($category_products, 0, $per_category);
        }
        $response[] = array(
            'id' => $cat['id'],
            'name' => $cat['name'],
            'products' => $category_products
        );
    }

    $payload = array('categories' => $response);
    if ($is_guest && $cache_key) {
        lpco_dms_guest_cache_set($cache_key, $payload);
    } elseif ($cache_key) {
        lpco_dms_auth_cache_set($cache_key, $payload);
    }
    dms_send_cache_headers('home_by_category_' . md5(wp_json_encode($payload)));
    return $payload;
}

/**
 * Guest brands endpoint with logo/thumbnail support
 */
function dms_ecom_resolve_brand_image_url($term) {
    if (!($term instanceof WP_Term)) {
        return '';
    }

    $candidates = array(
        dms_ecom_get_term_meta_value($term->term_id, 'thumbnail_id'),
        dms_ecom_get_term_meta_value($term->term_id, 'brand_logo_id'),
        dms_ecom_get_term_meta_value($term->term_id, 'brand_image_id'),
        dms_ecom_get_term_meta_value($term->term_id, 'brand_logo'),
        dms_ecom_get_term_meta_value($term->term_id, 'brand_image'),
    );

    foreach ($candidates as $id_or_url) {
        if (empty($id_or_url)) {
            continue;
        }
        if (is_numeric($id_or_url)) {
            $image_url = dms_ecom_get_attachment_url_cached($id_or_url);
        } else {
            $image_url = esc_url_raw($id_or_url);
        }
        if (!empty($image_url)) {
            return $image_url;
        }
    }

    return '';
}

function dms_get_brands_base($request) {
    $is_guest = lpco_dms_is_guest_request($request);
    list($current_user_id, $current_group, $current_currency) = dms_ecom_get_request_user_context($request, $is_guest);
    $cache_key = $is_guest
        ? lpco_dms_guest_cache_key('brands', $request)
        : lpco_dms_auth_cache_key('brands', $request, $current_user_id, $current_group, $current_currency);
    $cached = $is_guest ? lpco_dms_guest_cache_get($cache_key) : lpco_dms_auth_cache_get($cache_key);
    if ($cached !== false) {
        return $cached;
    }

    $per_page = max(1, intval($request->get_param('per_page') ?: 50));
    $page = max(1, intval($request->get_param('page') ?: 1));
    $taxonomy = taxonomy_exists('product_brand') ? 'product_brand' : 'product_tag';

    $terms = get_terms(array(
        'taxonomy' => $taxonomy,
        'hide_empty' => false,
        'number' => $per_page,
        'offset' => ($page - 1) * $per_page,
        'update_term_meta_cache' => true,
    ));

    if (is_wp_error($terms)) {
        return $terms;
    }

    $attachment_ids = array();
    foreach ($terms as $term) {
        foreach (array('thumbnail_id', 'brand_logo_id', 'brand_image_id') as $meta_key) {
            $attachment_id = absint(dms_ecom_get_term_meta_value($term->term_id, $meta_key));
            if ($attachment_id > 0) {
                $attachment_ids[$attachment_id] = $attachment_id;
            }
        }
    }
    dms_ecom_prime_attachment_ids($attachment_ids);

    $brands = array_map(function ($term) use ($taxonomy) {
        return array(
            'id' => $term->term_id,
            'name' => $term->name,
            'slug' => $term->slug,
            'count' => $term->count,
            'image_url' => dms_ecom_resolve_brand_image_url($term),
            'taxonomy' => $taxonomy
        );
    }, $terms);

    if (function_exists('lpco_app_layout_config_get') && function_exists('lpco_app_layout_apply_order')) {
        $config = lpco_app_layout_config_get();
        if (!empty($config['brands'])) {
            $brands = lpco_app_layout_apply_order($brands, $config['brands'], 'id');
        }
    }

    if ($is_guest && $cache_key) {
        lpco_dms_guest_cache_set($cache_key, $brands);
    } elseif ($cache_key) {
        lpco_dms_auth_cache_set($cache_key, $brands);
    }

    return $brands;
}

function dms_get_brands_guest($request) {
    wp_set_current_user(0);
    if (!$request->get_param('guest') && !$request->get_param('mode')) {
        $request->set_param('guest', 1);
    }
    $brands = dms_get_brands_base($request);
    if (is_wp_error($brands)) {
        return $brands;
    }
    dms_send_cache_headers('brands_guest_' . md5(wp_json_encode($brands)));
    return $brands;
}

/**
 * Authenticated brands endpoint with logo/thumbnail support
 */
function dms_get_brands_auth($request) {
    $brands = dms_get_brands_base($request);
    if (is_wp_error($brands)) {
        return $brands;
    }

    dms_send_cache_headers('brands_auth_' . md5(wp_json_encode($brands)));
    return $brands;
}
