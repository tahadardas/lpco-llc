function dms_ecom_get_bulk_post_meta($post_ids, $meta_keys) {
    global $wpdb;

    $post_ids = array_values(array_filter(array_map('absint', (array) $post_ids)));
    $meta_keys = array_values(array_filter(array_map('strval', (array) $meta_keys)));

    if (empty($post_ids) || empty($meta_keys)) {
        return array();
    }

    $post_placeholders = implode(',', array_fill(0, count($post_ids), '%d'));
    $meta_placeholders = implode(',', array_fill(0, count($meta_keys), '%s'));
    $prepared_query = $wpdb->prepare(
        "SELECT post_id, meta_key, meta_value
         FROM {$wpdb->postmeta}
         WHERE post_id IN ({$post_placeholders})
         AND meta_key IN ({$meta_placeholders})",
        array_merge($post_ids, $meta_keys)
    );

    if (!$prepared_query) {
        return array();
    }

    $rows = $wpdb->get_results($prepared_query);
    $meta_map = array();

    foreach ((array) $rows as $row) {
        $post_id = isset($row->post_id) ? (int) $row->post_id : 0;
        $meta_key = isset($row->meta_key) ? (string) $row->meta_key : '';
        if ($post_id <= 0 || $meta_key === '') {
            continue;
        }
        if (!isset($meta_map[$post_id])) {
            $meta_map[$post_id] = array();
        }
        if (!array_key_exists($meta_key, $meta_map[$post_id])) {
            $meta_map[$post_id][$meta_key] = maybe_unserialize($row->meta_value);
        }
    }

    return $meta_map;
}

function dms_ecom_get_request_user_context($request, $is_guest) {
    $current_user_id = $is_guest ? 0 : get_current_user_id();
    $requested_group = $request->get_param('user_group');
    $requested_currency = $request->get_param('currency');
    $current_group = '';
    $current_currency = '';

    if ($is_guest) {
        list($default_group, $default_currency) = dms_ecom_guest_defaults();
        $current_group = $requested_group ? sanitize_text_field($requested_group) : $default_group;
        $current_currency = $requested_currency ? sanitize_text_field($requested_currency) : $default_currency;
    } else {
        $all_user_meta = $current_user_id ? get_user_meta($current_user_id) : array();
        $current_group = $requested_group ? sanitize_text_field($requested_group) : (isset($all_user_meta['dms_user_group'][0]) ? (string) $all_user_meta['dms_user_group'][0] : '');
        $current_currency = $requested_currency ? sanitize_text_field($requested_currency) : (isset($all_user_meta['dms_user_currency'][0]) ? (string) $all_user_meta['dms_user_currency'][0] : 'syp');
    }

    if ($current_group === '') {
        $current_group = 'default';
    }
    if ($current_currency === '') {
        $current_currency = 'syp';
    }

    return array($current_user_id, $current_group, $current_currency);
}

function dms_ecom_prime_product_query_context($query, $has_brand_taxonomy) {
    $context = array(
        'post_ids' => array(),
        'products' => array(),
        'categories' => array(),
        'brands' => array(),
        'tags' => array(),
        'variations' => array(),
        'meta' => array(),
    );

    if (!($query instanceof WP_Query) || empty($query->posts)) {
        return $context;
    }

    $post_ids = array_values(array_filter(array_map('intval', wp_list_pluck($query->posts, 'ID'))));
    if (empty($post_ids)) {
        return $context;
    }

    $context['post_ids'] = $post_ids;
    $context['meta'] = dms_ecom_get_bulk_post_meta($post_ids, array('_dms_prices', '_custom_product_order'));

    _prime_post_caches($post_ids, false, true);
    update_post_thumbnail_cache($query);

    $taxonomies_to_prime = array('product_cat', 'product_tag');
    if ($has_brand_taxonomy) {
        $taxonomies_to_prime[] = 'product_brand';
    }
    update_object_term_cache($post_ids, array_values(array_unique($taxonomies_to_prime)));

    $attachment_ids = array();
    $term_ids = array();
    $variation_ids = array();

    foreach ($post_ids as $post_id) {
        $product = wc_get_product($post_id);
        if (!$product) {
            continue;
        }

        $context['products'][$post_id] = $product;

        $featured_id = $product->get_image_id();
        if ($featured_id) {
            $attachment_ids[$featured_id] = (int) $featured_id;
        }
        foreach ($product->get_gallery_image_ids() as $gallery_id) {
            $gallery_id = absint($gallery_id);
            if ($gallery_id > 0) {
                $attachment_ids[$gallery_id] = $gallery_id;
            }
        }

        $category_terms = get_the_terms($post_id, 'product_cat');
        if (!empty($category_terms) && !is_wp_error($category_terms)) {
            $context['categories'][$post_id] = $category_terms;
            foreach ($category_terms as $term) {
                $term_ids[$term->term_id] = (int) $term->term_id;
            }
        }

        $brand_terms = $has_brand_taxonomy ? get_the_terms($post_id, 'product_brand') : false;
        if (empty($brand_terms) || is_wp_error($brand_terms)) {
            $brand_terms = get_the_terms($post_id, 'product_tag');
        }
        if (!empty($brand_terms) && !is_wp_error($brand_terms)) {
            $context['brands'][$post_id] = $brand_terms;
            foreach ($brand_terms as $term) {
                $term_ids[$term->term_id] = (int) $term->term_id;
            }
        }

        $tag_terms = get_the_terms($post_id, 'product_tag');
        if (!empty($tag_terms) && !is_wp_error($tag_terms)) {
            $context['tags'][$post_id] = $tag_terms;
            foreach ($tag_terms as $term) {
                $term_ids[$term->term_id] = (int) $term->term_id;
            }
        }

        if ($product->is_type('variable')) {
            foreach ($product->get_children() as $variation_id) {
                $variation_id = absint($variation_id);
                if ($variation_id > 0) {
                    $variation_ids[$variation_id] = $variation_id;
                }
            }
        }
    }

    if (!empty($variation_ids)) {
        $variation_ids = array_values($variation_ids);
        _prime_post_caches($variation_ids, false, true);

        foreach ($variation_ids as $variation_id) {
            $variation_product = wc_get_product($variation_id);
            if (!$variation_product) {
                continue;
            }

            $context['variations'][$variation_id] = $variation_product;
            $variation_image_id = $variation_product->get_image_id();
            if ($variation_image_id) {
                $attachment_ids[$variation_image_id] = (int) $variation_image_id;
            }
        }
    }

    if (!empty($term_ids)) {
        update_meta_cache('term', array_values($term_ids));
        foreach ($term_ids as $term_id) {
            foreach (array('thumbnail_id', 'brand_logo_id', 'brand_image_id') as $meta_key) {
                $attachment_id = absint(dms_ecom_get_term_meta_value($term_id, $meta_key));
                if ($attachment_id > 0) {
                    $attachment_ids[$attachment_id] = $attachment_id;
                }
            }
        }
    }

    dms_ecom_prime_attachment_ids($attachment_ids);

    return $context;
}

function dms_get_products_with_prices($request) {
    $per_page = $request->get_param('per_page') ?: 100;
    $page = $request->get_param('page') ?: 1;
    $category = $request->get_param('category');
    $search = $request->get_param('search');
    $brand_slug = $request->get_param('brand_slug');
    $include = $request->get_param('include');
    $include_ids = array();
    if (!empty($include)) {
        $include_ids = array_values(array_filter(array_map('absint', explode(',', (string) $include))));
    }
    $stock_order = $request->get_param('stock_order');
    $latest_days = absint($request->get_param('latest_days'));
    $stock_status = $request->get_param('stock');
    $stock_status = $stock_status !== null ? sanitize_text_field($stock_status) : '';
    $is_guest = lpco_dms_is_guest_request($request);
    list($current_user_id, $current_group, $current_currency) = dms_ecom_get_request_user_context($request, $is_guest);
    $cache_key = $is_guest
        ? lpco_dms_guest_cache_key('products', $request)
        : lpco_dms_auth_cache_key('products', $request, $current_user_id, $current_group, $current_currency);
    $cached = $is_guest ? lpco_dms_guest_cache_get($cache_key) : lpco_dms_auth_cache_get($cache_key);
    if ($cached !== false) {
        if ($is_guest) {
            dms_send_cache_headers('products_guest_' . md5(wp_json_encode($cached)));
        }
        return $cached;
    }
    
    $has_brand_taxonomy = taxonomy_exists('product_brand');
    $args = dms_build_ordered_product_query_args(array(
        'posts_per_page' => $per_page,
        'paged' => $page,
        'stock_status' => $stock_status
    ));
    $args['no_found_rows'] = true;
    $args['update_post_meta_cache'] = true;
    $args['update_post_term_cache'] = true;
    $order_meta_key = dms_ecom_get_app_order_meta_key($brand_slug);
    if ($order_meta_key) {
        $args['meta_key'] = $order_meta_key;
        $args['orderby'] = 'meta_value_num';
        $args['order'] = 'ASC';
    }
    
    // Build tax_query for category and brand filtering
    $tax_query = array();
    
    // إضافة فلتر التصنيف
    if ($category) {
        $tax_query[] = array(
            'taxonomy' => 'product_cat',
            'field' => 'term_id',
            'terms' => $category
        );
    }
    
    // إضافة فلتر العلامة التجارية (Brand)
    // Try product_brand taxonomy first, fall back to product_tag
    if ($brand_slug) {
        $brand_query = array(
            'taxonomy' => $has_brand_taxonomy ? 'product_brand' : 'product_tag',
            'field' => 'slug',
            'terms' => $brand_slug
        );

        $tax_query[] = $brand_query;
    }
    
    // Apply tax_query if we have any filters
    if (!empty($tax_query)) {
        $args['tax_query'] = $tax_query;
        // If multiple tax queries, use AND relation
        if (count($tax_query) > 1) {
            $args['tax_query']['relation'] = 'AND';
        }
    }
    
    // إضافة البحث
    if ($search) {
        $args['s'] = $search;
    }

    if (!empty($include_ids)) {
        $args['post__in'] = $include_ids;
        $args['orderby'] = 'post__in';
        $args['posts_per_page'] = count($include_ids);
        $args['paged'] = 1;
    }

    if ($latest_days > 0 && dms_ecom_manual_latest_enabled() && empty($include_ids) && empty($category) && empty($search) && empty($brand_slug)) {
        $args['meta_query'] = array(
            array(
                'key' => '_dms_app_latest_order',
                'compare' => 'EXISTS'
            )
        );
        $args['meta_key'] = '_dms_app_latest_order';
        $args['orderby'] = 'meta_value_num';
        $args['order'] = 'ASC';
    } elseif ($latest_days > 0) {
        $after_ts = current_time('timestamp', true) - ($latest_days * DAY_IN_SECONDS);
        $args['date_query'] = array(
            array(
                'after' => gmdate('Y-m-d H:i:s', $after_ts),
                'inclusive' => true,
                'column' => 'post_date_gmt'
            )
        );
        $args['orderby'] = 'date';
        $args['order'] = 'DESC';
    }

    if ($stock_order === 'in_first' && empty($include_ids) && $latest_days <= 0) {
        if (empty($args['meta_query'])) {
            $args['meta_query'] = array();
        }
        $args['meta_query']['stock_status'] = array(
            'key' => '_stock_status',
            'compare' => 'EXISTS'
        );
        $args['orderby'] = array(
            'meta_value_num' => 'ASC',
            'stock_status' => 'ASC'
        );
    }
    
    $query = new WP_Query($args);
    $prepared = dms_ecom_prime_product_query_context($query, $has_brand_taxonomy);
    $product_meta_map = $prepared['meta'];
    $products = array();
    
    if ($query->have_posts()) {
        while ($query->have_posts()) {
            $query->the_post();
            $product_id = get_the_ID();
            $product = $prepared['products'][$product_id] ?? wc_get_product($product_id);
            
            if (!$product) continue;
            
            // جلب الأسعار المخصصة
            // _dms_prices structure:
            // {
            //   "group_name": {
            //     "syp_piece": "145200",           // Price per piece in SYP
            //     "usd_piece": "13.2",             // Price per piece in USD
            //     "box_unit_name": "علبة",         // Name of box unit
            //     "box_pieces_count": "12",        // Pieces in a box
            //     "package_unit_name": "طرد",      // Name of package unit
            //     "package_pieces_count": "60"     // Pieces in a package
            //   }
            // }
            $product_meta = $product_meta_map[$product_id] ?? array();
            $dms_prices = array_key_exists('_dms_prices', $product_meta)
                ? $product_meta['_dms_prices']
                : get_post_meta($product_id, '_dms_prices', true);

            $box_unit_name = 'علبة';
            $box_pieces_count = 0;
            $package_unit_name = 'طرد';
            $package_pieces_count = 0;
            if (is_array($dms_prices)) {
                $label_prices = $is_guest ? ($dms_prices['default'] ?? reset($dms_prices)) : ($dms_prices[$current_group] ?? ($dms_prices['default'] ?? array()));
                if (is_array($label_prices)) {
                    $box_unit_name = sanitize_text_field($label_prices['box_unit_name'] ?? $box_unit_name);
                    $box_pieces_count = absint($label_prices['box_pieces_count'] ?? 0);
                    $package_unit_name = sanitize_text_field($label_prices['package_unit_name'] ?? $package_unit_name);
                    $package_pieces_count = absint($label_prices['package_pieces_count'] ?? 0);
                }
            }
            
            // Build unit options (piece + package if available) based on user group
            $unit_options = array();
            if ($is_guest) {
                $base_price = floatval($product->get_price());
                $package_count = 0;
                $package_name = 'طرد';
                if (is_array($dms_prices)) {
                    $fallback_prices = $dms_prices['default'] ?? reset($dms_prices);
                    if (is_array($fallback_prices)) {
                        $package_count = intval($fallback_prices['package_pieces_count'] ?? 0);
                        $package_name = $fallback_prices['package_unit_name'] ?? $package_name;
                    }
                }
                if ($base_price > 0) {
                    $unit_options[] = array(
                        'type' => 'piece',
                        'name' => 'قطعة',
                        'pieces_count' => 1,
                        'price' => $base_price,
                        'currency' => $current_currency
                    );
                }
                if ($base_price > 0 && $package_count > 0) {
                    $unit_options[] = array(
                        'type' => 'package',
                        'name' => $package_name ?: 'طرد',
                        'pieces_count' => $package_count,
                        'price' => $base_price * $package_count,
                        'currency' => $current_currency
                    );
                }
            } elseif (is_array($dms_prices)) {
                $user_prices = $dms_prices[$current_group] ?? ($dms_prices['default'] ?? array());
                if (!empty($user_prices) && is_array($user_prices)) {
                    $price_key = strtolower($current_currency) === 'usd' ? 'usd_piece' : 'syp_piece';
                    $piece_price = floatval($user_prices[$price_key] ?? 0);
                    if ($piece_price <= 0) {
                        $piece_price = floatval($product->get_price());
                    }
                    if ($piece_price <= 0) {
                        $piece_price = floatval($product->get_regular_price());
                    }
                    $package_count = intval($user_prices['package_pieces_count'] ?? 0);
                    $package_name = $user_prices['package_unit_name'] ?? 'طرد';
                    
                    if ($piece_price > 0) {
                        $unit_options[] = array(
                            'type' => 'piece',
                            'name' => 'قطعة',
                            'pieces_count' => 1,
                            'price' => $piece_price,
                            'currency' => $current_currency
                        );
                    }
                    
                    if ($piece_price > 0 && $package_count > 0) {
                        $unit_options[] = array(
                            'type' => 'package',
                            'name' => $package_name ?: 'طرد',
                            'pieces_count' => $package_count,
                            'price' => $piece_price * $package_count,
                            'currency' => $current_currency
                        );
                    }
                }
            }
            
            // بناء بيانات المنتج
            if (!empty($unit_options)) {
                foreach ($unit_options as &$unit_option) {
                    $label_unit_type = $unit_option['type'] ?? '';
                    $label_name = $unit_option['name'] ?? '';
                    $label_pieces = $unit_option['pieces_count'] ?? null;

                    if ($label_unit_type === 'package') {
                        if ($package_unit_name !== '') {
                            $label_name = $package_unit_name;
                        }
                        if ($package_pieces_count > 0) {
                            $label_pieces = $package_pieces_count;
                        }
                    } else {
                        if ($box_unit_name !== '') {
                            $label_name = $box_unit_name;
                        }
                        if ($box_pieces_count > 0) {
                            $label_pieces = $box_pieces_count;
                        }
                    }

                    $labels = dms_get_unit_label_display($product_id, $label_unit_type, 'api', $label_name, $label_pieces, $current_group);
                    $unit_option['label_display_ar'] = $labels['ar'];
                    if (!empty($labels['en'])) {
                        $unit_option['label_display_en'] = $labels['en'];
                    }
                }
                unset($unit_option);
            }

            $unit_display_default_ar = null;
            $unit_display_default_en = null;
            if (!empty($unit_options)) {
                $first_option = $unit_options[0];
                $unit_display_default_ar = $first_option['label_display_ar'] ?? null;
                $unit_display_default_en = $first_option['label_display_en'] ?? null;
            }

            $custom_order = array_key_exists('_custom_product_order', $product_meta)
                ? $product_meta['_custom_product_order']
                : get_post_meta($product_id, '_custom_product_order', true);
            $custom_order_value = ($custom_order !== '' && $custom_order !== null)
                ? intval($custom_order)
                : DMS_ECOM_CUSTOM_PRODUCT_ORDER_DEFAULT;
            $image_id = $product->get_image_id();
            $image_url = $image_id ? dms_ecom_get_attachment_url_cached($image_id) : '';
            $brand_slug_value = '';
            $brand_terms = $prepared['brands'][$product_id] ?? array();
            if (!empty($brand_terms)) {
                $brand_slug_value = $brand_terms[0]->slug;
            }
            $created_ts = dms_ecom_get_product_created_ts($product_id, $product);
            $post_object = get_post($product_id);
            $published_gmt = $post_object ? $post_object->post_date_gmt : '';
            $published_local = $post_object ? $post_object->post_date : '';
            $age_days = null;
            $is_new = dms_ecom_is_new_product($created_ts, $age_days);
            $category_terms = $prepared['categories'][$product_id] ?? array();

            // Response structure for each product:
            $product_data = array(
                'id' => $product_id,
                'name' => $product->get_name(),
                'slug' => $product->get_slug(),
                'permalink' => get_permalink($product_id),
                'type' => $product->get_type(),
                'status' => $product->get_status(),
                'description' => $product->get_description(),
                'short_description' => $product->get_short_description(),
                'sku' => $product->get_sku(),
                'price' => $product->get_price(),                    // Fallback price
                'regular_price' => $product->get_regular_price(),
                'sale_price' => $product->get_sale_price(),
                'custom_order' => $custom_order_value,
                'stock_status' => $product->get_stock_status() ?: 'outofstock',
                'stock_quantity' => $product->get_stock_quantity(),
                'image_url' => $image_url,
                'brand_slug' => $brand_slug_value,
                'is_new' => $is_new,
                'new_badge_label_ar' => 'حديث',
                'new_badge_days' => DMS_NEW_DAYS,
                'created_at_gmt' => $created_ts ? gmdate('c', $created_ts) : null,
                'published_at_gmt' => $published_gmt ? gmdate('c', strtotime($published_gmt)) : null,
                'published_at_local' => $published_local ? date('c', strtotime($published_local)) : null,
                'categories' => array_map(function($term) {
                    return array(
                        'id' => $term->term_id,
                        'name' => $term->name,
                        'slug' => $term->slug
                    );
                }, $category_terms ?: array()),
                'images' => array_map(function($image_id) {
                    return array(
                        'id' => $image_id,
                        'src' => dms_ecom_get_attachment_url_cached($image_id),
                        'name' => dms_ecom_get_attachment_title_cached($image_id),
                        'alt' => dms_ecom_get_attachment_alt_cached($image_id)
                    );
                }, $product->get_gallery_image_ids()),
                'unit_options' => $unit_options,
                'unit_display_default_ar' => $unit_display_default_ar,
                'unit_display_default_en' => $unit_display_default_en,
                // meta_data contains DMS pricing info
                // Client reads: meta_data[].key === '_dms_prices' to get group-based prices
                'meta_data' => array(
                    array(
                        'key' => '_dms_prices',
                        'value' => $dms_prices ?: array()
                    )
                )
            );
            
            // إضافة الصورة الرئيسية
            if ($image_id) {
                array_unshift($product_data['images'], array(
                    'id' => $image_id,
                    'src' => dms_ecom_get_attachment_url_cached($image_id),
                    'name' => dms_ecom_get_attachment_title_cached($image_id),
                    'alt' => dms_ecom_get_attachment_alt_cached($image_id)
                ));
            }
            
            $products[] = $product_data;
        }
    }
    
    wp_reset_postdata();

    $products = dms_ecom_partition_new_first($products);

    if ($is_guest && $cache_key) {
        lpco_dms_guest_cache_set($cache_key, $products);
        dms_send_cache_headers('products_guest_' . md5(wp_json_encode($products)));
    } elseif ($cache_key) {
        lpco_dms_auth_cache_set($cache_key, $products);
    }
    return $products;
}

