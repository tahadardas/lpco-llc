/**
 * Register a new user from mobile app
 */
function dms_register_user($request) {
    $params = $request->get_json_params();
    $ip = dms_ecom_get_client_ip();
    
    $rate_check = dms_ecom_rate_limit('register', $ip);
    if (is_wp_error($rate_check)) {
        return $rate_check;
    }
    
    $captcha_check = dms_ecom_validate_captcha_if_required($params['captcha_token'] ?? '', $ip);
    if (is_wp_error($captcha_check)) {
        return $captcha_check;
    }
    
    // Validate required fields
    if (empty($params['username']) || empty($params['password']) || empty($params['email'])) {
        return new WP_Error('invalid_params', 'Username, email, and password are required.', array('status' => 400));
    }
    
    $username = sanitize_user($params['username']);
    $email = sanitize_email($params['email']);
    $password = $params['password'];
    $first_name = sanitize_text_field($params['first_name'] ?? '');
    $last_name = sanitize_text_field($params['last_name'] ?? '');
    $display_name = sanitize_text_field($params['display_name'] ?? ($params['name'] ?? $first_name));
    
    if (strlen($username) < 3) {
        return new WP_Error('invalid_username', 'Username must be at least 3 characters.', array('status' => 400));
    }
    
    if (!is_email($email)) {
        return new WP_Error('invalid_email', 'Email address is invalid.', array('status' => 400));
    }
    
    if (strlen($password) < 6) {
        return new WP_Error('weak_password', 'Password must be at least 6 characters.', array('status' => 400));
    }
    
    // Check if username exists
    if (username_exists($username)) {
        return new WP_Error('username_exists', 'Username already exists.', array('status' => 400));
    }
    
    // Check if email exists
    if (email_exists($email)) {
        return new WP_Error('email_exists', 'Email already exists.', array('status' => 400));
    }
    
    // Create user
    $user_id = wp_create_user($username, $password, $email);
    
    if (is_wp_error($user_id)) {
        return new WP_Error('registration_failed', 'Could not complete registration.', array('status' => 500));
    }
    
    // Set user meta
    $user_update = array(
        'ID' => $user_id,
        'first_name' => $first_name
    );
    if ($last_name !== '') {
        $user_update['last_name'] = $last_name;
    }
    if ($display_name !== '') {
        $user_update['display_name'] = $display_name;
    }
    wp_update_user($user_update);
    
    // Set DMS meta
    $default_status = function_exists('dms_get_default_account_status') ? dms_get_default_account_status() : 'جديد';
    update_user_meta($user_id, 'dms_user_group', 'default');
    update_user_meta($user_id, 'dms_user_currency', 'syp');
    update_user_meta($user_id, 'dms_account_status', $default_status);
    
    $meta = (isset($params['meta']) && is_array($params['meta'])) ? $params['meta'] : array();
    $extra = array(
        'phone' => sanitize_text_field($params['phone'] ?? ($params['billing_phone'] ?? ($meta['phone'] ?? ''))),
        'company' => sanitize_text_field($params['company'] ?? ($params['billing_company'] ?? ($meta['company'] ?? ''))),
        'whatsapp' => sanitize_text_field($params['whatsapp'] ?? ($meta['whatsapp'] ?? '')),
        'whatsapp_country_code' => sanitize_text_field($params['whatsapp_country_code'] ?? ($meta['whatsapp_country_code'] ?? '')),
        'governorate' => sanitize_text_field($params['governorate'] ?? ($params['province'] ?? ($params['billing_state'] ?? ($meta['governorate'] ?? ($meta['province'] ?? ''))))),
        'address' => sanitize_text_field($params['address'] ?? ($params['billing_address_1'] ?? ($meta['address'] ?? ''))),
        'group' => sanitize_text_field($params['group'] ?? ($meta['dms_user_group'] ?? '')),
        'currency' => sanitize_text_field($params['currency'] ?? ($meta['dms_user_currency'] ?? '')),
        'status' => sanitize_text_field($params['status'] ?? ($meta['dms_account_status'] ?? '')),
        'display_name' => $display_name,
        'first_name' => $first_name,
        'last_name' => $last_name,
        'billing_phone' => sanitize_text_field($params['billing_phone'] ?? ''),
        'billing_company' => sanitize_text_field($params['billing_company'] ?? ''),
        'billing_state' => sanitize_text_field($params['billing_state'] ?? ''),
        'billing_address_1' => sanitize_text_field($params['billing_address_1'] ?? '')
    );
    if (!empty($extra['phone'])) {
        update_user_meta($user_id, 'phone', $extra['phone']);
    }
    if (!empty($extra['company'])) {
        update_user_meta($user_id, 'company', $extra['company']);
    }
    if (!empty($extra['governorate'])) {
        update_user_meta($user_id, 'province', $extra['governorate']);
    }
    if (!empty($extra['address'])) {
        update_user_meta($user_id, 'address', $extra['address']);
    }

    if (get_user_meta($user_id, 'account_company_name', true) === '' && !empty($extra['company'])) {
        update_user_meta($user_id, 'account_company_name', $extra['company']);
    }
    if (get_user_meta($user_id, 'account_whatsapp', true) === '' && !empty($extra['phone'])) {
        update_user_meta($user_id, 'account_whatsapp', $extra['phone']);
    }
    if (get_user_meta($user_id, 'account_whatsapp_country_code', true) === '' && !empty($extra['whatsapp_country_code'])) {
        update_user_meta($user_id, 'account_whatsapp_country_code', $extra['whatsapp_country_code']);
    }
    if (get_user_meta($user_id, 'account_governorate', true) === '' && !empty($extra['governorate'])) {
        update_user_meta($user_id, 'account_governorate', $extra['governorate']);
    }

    if (function_exists('dms_sync_member_record')) {
        dms_sync_member_record($user_id, $extra);
    }

    // Set user role
    $user = new WP_User($user_id);
    $user->set_role('customer');
    
    dms_ecom_log('info', 'New user registered via API', array('user_id' => $user_id, 'ip' => $ip));
    if (function_exists('dms_ecom_notify_admin_new_user')) {
        dms_ecom_notify_admin_new_user($user_id, $extra);
    }
    
    return array(
        'id' => $user_id,
        'username' => $username,
        'email' => $email,
        'message' => 'Account created successfully'
    );
}
