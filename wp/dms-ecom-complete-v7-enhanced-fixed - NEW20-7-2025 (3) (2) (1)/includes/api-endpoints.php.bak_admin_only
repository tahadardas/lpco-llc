// Enhanced products endpoint (v2) - leaves legacy /products intact
function dms_ecom_is_color_attribute_key($key) {
    if (!is_string($key) || $key === '') {
        return false;
    }
    $normalized = strtolower($key);
    if (strpos($normalized, 'color') !== false || strpos($normalized, 'colour') !== false) {
        return true;
    }
    return strpos($key, 'لون') !== false;
}

function dms_ecom_extract_color_from_attributes($attributes) {
    static $term_cache = array();

    if (!is_array($attributes)) {
        return array('', '', '');
    }
    foreach ($attributes as $attr_key => $attr_value) {
        if (!dms_ecom_is_color_attribute_key($attr_key)) {
            continue;
        }
        $taxonomy = $attr_key;
        if (strpos($taxonomy, 'attribute_') === 0) {
            $taxonomy = substr($taxonomy, 10);
        }
        $value = is_array($attr_value) ? (string) reset($attr_value) : (string) $attr_value;
        $value = trim($value);
        if ($value === '') {
            continue;
        }
        $color_name = $value;
        $color_slug = $value;
        $color_hex = '';
        if ($taxonomy && taxonomy_exists($taxonomy)) {
            $term_cache_key = $taxonomy . '::' . $value;
            if (!array_key_exists($term_cache_key, $term_cache)) {
                $term_cache[$term_cache_key] = get_term_by('slug', $value, $taxonomy);
            }
            $term = $term_cache[$term_cache_key];
            if ($term && !is_wp_error($term)) {
                $color_name = $term->name;
                $color_slug = $term->slug;
                $all_term_meta = dms_ecom_get_all_term_meta($term->term_id);
                $hex = $all_term_meta['color'][0] ?? '';
                if (empty($hex)) {
                    $hex = $all_term_meta['product_attribute_color'][0] ?? '';
                }
                if (empty($hex)) {
                    $hex = $all_term_meta['_color'][0] ?? '';
                }
                if (!empty($hex)) {
                    $color_hex = sanitize_hex_color($hex);
                }
            }
        }
        return array($color_name, $color_slug, $color_hex);
    }
    return array('', '', '');
}

function dms_get_products_plus($request) {
    $per_page = $request->get_param('per_page') ?: 100;
    $page = $request->get_param('page') ?: 1;
    $category = $request->get_param('category');
    $search = $request->get_param('search');
    $brand_slug = $request->get_param('brand_slug');
    $stock_order = $request->get_param('stock_order');
    $latest_days = absint($request->get_param('latest_days'));
    $stock_status = $request->get_param('stock');
    $stock_status = $stock_status !== null ? sanitize_text_field($stock_status) : '';
    $include = $request->get_param('include');
    $include_ids = array();
    if (!empty($include)) {
        $include_ids = array_values(array_filter(array_map('absint', explode(',', (string) $include))));
    }
    $is_guest = lpco_dms_is_guest_request($request);
    list($current_user_id, $current_group, $current_currency) = dms_ecom_get_request_user_context($request, $is_guest);
    $cache_key = $is_guest
        ? lpco_dms_guest_cache_key('products_plus', $request)
        : lpco_dms_auth_cache_key('products_plus', $request, $current_user_id, $current_group, $current_currency);
    $cached = $is_guest ? lpco_dms_guest_cache_get($cache_key) : lpco_dms_auth_cache_get($cache_key);
    if ($cached !== false) {
        if ($is_guest) {
            dms_send_cache_headers('products_plus_guest_' . md5(wp_json_encode($cached)));
        }
        return $cached;
    }
    
    $has_brand_taxonomy = taxonomy_exists('product_brand');
    $args = dms_build_ordered_product_query_args(array(
        'posts_per_page' => $per_page,
        'paged' => $page,
        'stock_status' => $stock_status
    ));
    $args['no_found_rows'] = true;
    $args['update_post_meta_cache'] = true;
    $args['update_post_term_cache'] = true;
    
    $tax_query = array();
    if ($category) {
        $tax_query[] = array(
            'taxonomy' => 'product_cat',
            'field' => 'term_id',
            'terms' => $category
        );
    }
    if ($brand_slug) {
        $brand_query = array(
            'taxonomy' => $has_brand_taxonomy ? 'product_brand' : 'product_tag',
            'field' => 'slug',
            'terms' => $brand_slug
        );
        $tax_query[] = $brand_query;
    }
    if (!empty($tax_query)) {
        $args['tax_query'] = $tax_query;
        if (count($tax_query) > 1) {
            $args['tax_query']['relation'] = 'AND';
        }
    }
    if ($search) {
        $args['s'] = $search;
    }

    if (!empty($include_ids)) {
        $args['post__in'] = $include_ids;
        $args['orderby'] = 'post__in';
        $args['posts_per_page'] = count($include_ids);
        $args['paged'] = 1;
    }

    if ($latest_days > 0 && dms_ecom_manual_latest_enabled() && empty($include_ids) && empty($category) && empty($search) && empty($brand_slug)) {
        $args['meta_query'] = array(
            array(
                'key' => '_dms_app_latest_order',
                'compare' => 'EXISTS'
            )
        );
        $args['meta_key'] = '_dms_app_latest_order';
        $args['orderby'] = 'meta_value_num';
        $args['order'] = 'ASC';
    } elseif ($latest_days > 0) {
        $after_ts = current_time('timestamp', true) - ($latest_days * DAY_IN_SECONDS);
        $args['date_query'] = array(
            array(
                'after' => gmdate('Y-m-d H:i:s', $after_ts),
                'inclusive' => true,
                'column' => 'post_date_gmt'
            )
        );
        $args['orderby'] = 'date';
        $args['order'] = 'DESC';
    }

    if ($stock_order === 'in_first' && empty($include_ids) && $latest_days <= 0) {
        if (empty($args['meta_query'])) {
            $args['meta_query'] = array();
        }
        $args['meta_query']['stock_status'] = array(
            'key' => '_stock_status',
            'compare' => 'EXISTS'
        );
        $args['orderby'] = array(
            'meta_value_num' => 'ASC',
            'stock_status' => 'ASC'
        );
    }
    
    $query = new WP_Query($args);
    $prepared = dms_ecom_prime_product_query_context($query, $has_brand_taxonomy);
    $product_meta_map = $prepared['meta'];
    $products = array();
    
    if (defined('DMS_ECOM_DEBUG') && DMS_ECOM_DEBUG) {
        $debug_args = array(
            'args' => $args,
            'found_posts' => intval($query->found_posts),
            'post_count' => intval($query->post_count),
        );
        dms_ecom_log('debug', 'products-plus query', $debug_args);
    }
    
    if ($query->have_posts()) {
        while ($query->have_posts()) {
            $query->the_post();
            $product_id = get_the_ID();
            $product = $prepared['products'][$product_id] ?? wc_get_product($product_id);
            if (!$product) continue;
            
            $product_meta = $product_meta_map[$product_id] ?? array();
            $dms_prices = array_key_exists('_dms_prices', $product_meta)
                ? $product_meta['_dms_prices']
                : get_post_meta($product_id, '_dms_prices', true);
            if ($is_guest) {
                $fallback_prices = is_array($dms_prices) ? ($dms_prices['default'] ?? reset($dms_prices)) : array();
                if (!is_array($fallback_prices)) $fallback_prices = array();
                
                $piece_price = floatval($product->get_price());
                $package_count = intval($fallback_prices['package_pieces_count'] ?? 0);
                $package_name = $fallback_prices['package_unit_name'] ?? 'طرد';
            } else {
                $fallback_from_default = is_array($dms_prices) ? ($dms_prices['default'] ?? reset($dms_prices)) : array();
                if (!is_array($fallback_from_default)) $fallback_from_default = array();

                $group_prices = (is_array($dms_prices) && isset($dms_prices[$current_group]) && is_array($dms_prices[$current_group])) ? $dms_prices[$current_group] : array();
                
                $user_prices = array_merge($fallback_from_default, $group_prices);

                $price_key = strtolower($current_currency) === 'usd' ? 'usd_piece' : 'syp_piece';
                $piece_price = floatval($user_prices[$price_key] ?? 0);
                if ($piece_price <= 0) {
                    $piece_price = floatval($product->get_price());
                }
                if ($piece_price <= 0) {
                    $piece_price = floatval($product->get_regular_price());
                }
                $package_count = intval($user_prices['package_pieces_count'] ?? 0);
                $package_name = $user_prices['package_unit_name'] ?? 'طرد';
            }

            $box_unit_name = 'علبة';
            $box_pieces_count = 0;
            $package_unit_name = 'طرد';
            $package_pieces_count = 0;
            $label_prices = $is_guest ? $fallback_prices : $user_prices;
            if (is_array($label_prices)) {
                $box_unit_name = sanitize_text_field($label_prices['box_unit_name'] ?? $box_unit_name);
                $box_pieces_count = absint($label_prices['box_pieces_count'] ?? 0);
                $package_unit_name = sanitize_text_field($label_prices['package_unit_name'] ?? $package_unit_name);
                $package_pieces_count = absint($label_prices['package_pieces_count'] ?? 0);
            }
            
            $unit_options = array();
            if ($piece_price > 0) {
                $unit_options[] = array(
                    'type' => 'piece',
                    'name' => 'قطعة',
                    'pieces_count' => 1,
                    'price' => $piece_price,
                    'currency' => $current_currency
                );
            }
            if ($piece_price > 0 && $package_count > 0) {
                $unit_options[] = array(
                    'type' => 'package',
                    'name' => $package_name ?: 'طرد',
                    'pieces_count' => $package_count,
                    'price' => $piece_price * $package_count,
                    'currency' => $current_currency
                );
            }

            if (!empty($unit_options)) {
                foreach ($unit_options as &$unit_option) {
                    $label_unit_type = $unit_option['type'] ?? '';
                    $label_name = $unit_option['name'] ?? '';
                    $label_pieces = $unit_option['pieces_count'] ?? null;

                    if ($label_unit_type === 'package') {
                        if ($package_unit_name !== '') {
                            $label_name = $package_unit_name;
                        }
                        if ($package_pieces_count > 0) {
                            $label_pieces = $package_pieces_count;
                        }
                    } else {
                        if ($box_unit_name !== '') {
                            $label_name = $box_unit_name;
                        }
                        if ($box_pieces_count > 0) {
                            $label_pieces = $box_pieces_count;
                        }
                    }

                    $labels = dms_get_unit_label_display($product_id, $label_unit_type, 'api', $label_name, $label_pieces, $current_group);
                    $unit_option['label_display_ar'] = $labels['ar'];
                    if (!empty($labels['en'])) {
                        $unit_option['label_display_en'] = $labels['en'];
                    }
                }
                unset($unit_option);
            }

            $unit_display_default_ar = null;
            $unit_display_default_en = null;
            if (!empty($unit_options)) {
                $first_option = $unit_options[0];
                $unit_display_default_ar = $first_option['label_display_ar'] ?? null;
                $unit_display_default_en = $first_option['label_display_en'] ?? null;
            }
            
            $brand_term = null;
            $brand_terms = $prepared['brands'][$product_id] ?? array();
            if (!empty($brand_terms)) {
                $brand_term = $brand_terms[0];
            }
            $brand_image = '';
            if ($brand_term) {
                $brand_thumb_id = dms_ecom_get_term_meta_value($brand_term->term_id, 'thumbnail_id');
                if ($brand_thumb_id) {
                    $brand_image = dms_ecom_get_attachment_url_cached($brand_thumb_id);
                }
                if (empty($brand_image)) {
                    $brand_image = dms_ecom_get_term_meta_value($brand_term->term_id, 'brand_image') ?: '';
                }
            }
            $brand_data = $brand_term ? array(
                'id' => $brand_term->term_id,
                'name' => $brand_term->name,
                'slug' => $brand_term->slug,
                'image_url' => $brand_image
            ) : null;
            
            $categories = array();
            $category_terms = $prepared['categories'][$product_id] ?? array();
            if (!empty($category_terms)) {
                foreach ($category_terms as $cat) {
                    $thumb_id = dms_ecom_get_term_meta_value($cat->term_id, 'thumbnail_id');
                    $thumb_url = $thumb_id ? dms_ecom_get_attachment_url_cached($thumb_id) : '';
                    $categories[] = array(
                        'id' => $cat->term_id,
                        'name' => $cat->name,
                        'slug' => $cat->slug,
                        'image_url' => $thumb_url,
                        'count' => $cat->count
                    );
                }
            }
            
            $attributes = array();
            foreach ($product->get_attributes() as $attr_obj) {
                if (is_a($attr_obj, 'WC_Product_Attribute')) {
                    $options = $attr_obj->get_options();
                    if (is_array($options)) {
                        $options = array_values(array_map('wc_clean', array_map('strval', $options)));
                    }
                    $attributes[] = array(
                        'name' => $attr_obj->get_name(),
                        'slug' => $attr_obj->get_name(),
                        'options' => $options,
                        'variation' => $attr_obj->get_variation(),
                        'visible' => $attr_obj->get_visible(),
                        'required' => $attr_obj->get_variation() ? true : false
                    );
                }
            }
            
            $variations = array();
            $color_options = array();
            if ($product->is_type('variable')) {
                $variation_ids = $product->get_children();
                foreach ($variation_ids as $variation_id) {
                    $variation_product = $prepared['variations'][$variation_id] ?? wc_get_product($variation_id);
                    if (!$variation_product) {
                        continue;
                    }
                    $raw_attributes = $variation_product->get_attributes();
                    $attributes_payload = array();
                    foreach ($raw_attributes as $attr_key => $attr_value) {
                        $attr_value = is_array($attr_value) ? reset($attr_value) : $attr_value;
                        $normalized_key = (strpos($attr_key, 'attribute_') === 0)
                            ? $attr_key
                            : 'attribute_' . $attr_key;
                        $attributes_payload[$normalized_key] = $attr_value;
                    }
                    list($color_name, $color_slug, $color_hex) = dms_ecom_extract_color_from_attributes($attributes_payload);
                    $is_in_stock = $variation_product->is_in_stock();
                    $stock_quantity = $variation_product->get_stock_quantity();
                    $image_id = $variation_product->get_image_id();
                    $image_url = $image_id ? dms_ecom_get_attachment_url_cached($image_id) : '';
                    $regular_price = floatval($variation_product->get_regular_price());
                    $price = floatval($variation_product->get_price());
                    $sale_price = ($regular_price > 0 && $price < $regular_price) ? $price : null;

                    $variations[] = array(
                        'id' => $variation_id,
                        'variation_id' => $variation_id,
                        'price' => $price,
                        'regular_price' => $regular_price,
                        'sale_price' => $sale_price,
                        'stock_status' => $is_in_stock ? 'instock' : 'outofstock',
                        'is_in_stock' => $is_in_stock,
                        'stock_quantity' => $stock_quantity !== null ? intval($stock_quantity) : null,
                        'image' => array(
                            'src' => $image_url
                        ),
                        'attributes' => $attributes_payload,
                        'color_name' => $color_name,
                        'color_slug' => $color_slug,
                        'color_hex' => $color_hex
                    );

                    $color_key = $color_slug ?: $color_name;
                    if ($color_key !== '') {
                        $existing = $color_options[$color_key] ?? null;
                        if (!$existing || (!$existing['is_in_stock'] && $is_in_stock)) {
                            $color_options[$color_key] = array(
                                'color_name' => $color_name ?: $color_slug,
                                'color_slug' => $color_slug ?: $color_name,
                                'variation_id' => $variation_id,
                                'is_in_stock' => $is_in_stock,
                                'stock_quantity' => $stock_quantity !== null ? intval($stock_quantity) : null,
                                'price' => $price,
                                'regular_price' => $regular_price,
                                'sale_price' => $sale_price,
                                'color_hex' => $color_hex
                            );
                        }
                    }
                }
            }
            
            $images = array();
            $featured_id = $product->get_image_id();
            if ($featured_id) {
                $images[] = array(
                    'id' => $featured_id,
                    'src' => dms_ecom_get_attachment_url_cached($featured_id),
                    'alt' => dms_ecom_get_attachment_alt_cached($featured_id)
                );
            }
            $gallery_ids = $product->get_gallery_image_ids();
            if (!empty($gallery_ids)) {
                foreach ($gallery_ids as $gid) {
                    $images[] = array(
                        'id' => $gid,
                        'src' => dms_ecom_get_attachment_url_cached($gid),
                        'alt' => dms_ecom_get_attachment_alt_cached($gid)
                    );
                }
            }
            
            $custom_order = array_key_exists('_custom_product_order', $product_meta)
                ? $product_meta['_custom_product_order']
                : get_post_meta($product_id, '_custom_product_order', true);
            $custom_order_value = ($custom_order !== '' && $custom_order !== null)
                ? intval($custom_order)
                : DMS_ECOM_CUSTOM_PRODUCT_ORDER_DEFAULT;
            $image_url = '';
            if (!empty($images)) {
                $image_url = $images[0]['src'] ?? '';
            }
            $created_ts = dms_ecom_get_product_created_ts($product_id, $product);
            $post_object = get_post($product_id);
            $published_gmt = $post_object ? $post_object->post_date_gmt : '';
            $published_local = $post_object ? $post_object->post_date : '';
            $age_days = null;
            $is_new = dms_ecom_is_new_product($created_ts, $age_days);

            $product_data = array(
                'id' => $product_id,
                'name' => $product->get_name(),
                'slug' => $product->get_slug(),
                'sku' => $product->get_sku(),
                'permalink' => get_permalink($product_id),
                'type' => $product->get_type(),
                'status' => $product->get_status(),
                'description' => $product->get_description(),
                'short_description' => $product->get_short_description(),
                'price' => floatval($product->get_price()),
                'regular_price' => floatval($product->get_regular_price()),
                'sale_price' => floatval($product->get_sale_price()),
                'custom_order' => $custom_order_value,
                'stock_status' => $product->get_stock_status() ?: 'outofstock',
                'stock_quantity' => $product->get_stock_quantity(),
                'image_url' => $image_url,
                'images' => $images,
                'is_new' => $is_new,
                'new_badge_label_ar' => 'حديث',
                'new_badge_days' => DMS_NEW_DAYS,
                'created_at_gmt' => $created_ts ? gmdate('c', $created_ts) : null,
                'published_at_gmt' => $published_gmt ? gmdate('c', strtotime($published_gmt)) : null,
                'published_at_local' => $published_local ? date('c', strtotime($published_local)) : null,
                'categories' => $categories,
                'tags' => $prepared['tags'][$product_id] ?? array(),
                'meta_data' => array(
                    array(
                        'key' => '_dms_prices',
                        'value' => is_array($dms_prices) ? $dms_prices : new stdClass()
                    )
                ),
                'unit_options' => $unit_options,
                'unit_display_default_ar' => $unit_display_default_ar,
                'unit_display_default_en' => $unit_display_default_en,
                'pack_size' => $package_count ?: null,
                'price_per_piece' => $piece_price,
                'price_per_pack' => ($package_count > 0) ? $piece_price * $package_count : null,
                'brand' => $brand_data,
                'brand_image' => $brand_image,
                'attributes' => $attributes,
                'variations' => $variations,
                'color_options' => array_values($color_options)
            );
            
            $products[] = $product_data;
        }
    }
    
    wp_reset_postdata();

    $products = dms_ecom_partition_new_first($products);

    if ($is_guest && $cache_key) {
        lpco_dms_guest_cache_set($cache_key, $products);
        dms_send_cache_headers('products_plus_guest_' . md5(wp_json_encode($products)));
    } elseif ($cache_key) {
        lpco_dms_auth_cache_set($cache_key, $products);
    }
    return $products;
}

/**
 * Get product categories with product counts
 */
function dms_get_categories($request) {
    $categories = dms_get_categories_base($request);
    if (is_wp_error($categories)) {
        return new WP_Error('categories_error', 'فشل جلب التصنيفات', array('status' => 500));
    }
    $payload = array_map(function($category) {
        $category['image'] = $category['image_url'];
        return $category;
    }, $categories);
    dms_send_cache_headers('categories_legacy_' . md5(wp_json_encode($payload)));
    return $payload;
}

