/**
 * Create a new order from mobile app
 * Wrapped with try-catch to prevent fatal errors and 500 responses
 */
function dms_create_order($request) {
    try {
        $params = $request->get_json_params();
        
        // Ensure params is an array
        if (!is_array($params)) {
            return new WP_Error('invalid_json', 'Request body must be valid JSON.', array('status' => 400));
        }
        
        // Verify WooCommerce is active
        if (!function_exists('wc_create_order')) {
            return new WP_Error('woocommerce_missing', 'WooCommerce is not active.', array('status' => 500));
        }
        
        $meta_entries = is_array($params['meta_data'] ?? null) ? $params['meta_data'] : array();
        $order_meta = array();
        foreach ($meta_entries as $entry) {
            if (isset($entry['key']) && array_key_exists('value', $entry)) {
                $order_meta[$entry['key']] = $entry['value'];
            }
        }
        $order_uuid = sanitize_text_field($params['order_uuid'] ?? ($order_meta['order_uuid'] ?? ''));
        
        // Validate required fields
        if (empty($params['customer_id']) || empty($params['line_items']) || !is_array($params['line_items'])) {
            return new WP_Error('invalid_params', 'Customer ID and line items are required.', array('status' => 400));
        }
        
        $customer_id = intval($params['customer_id']);
        $current_user_id = get_current_user_id();
        
        if ($current_user_id && $current_user_id !== $customer_id) {
            return new WP_Error('forbidden_order', 'You cannot create an order for this user.', array('status' => 403));
        }

    // Idempotency: if order_uuid already used, return existing order
    if (!empty($order_uuid)) {
        $existing = wc_get_orders(array(
            'limit' => 1,
            'meta_key' => 'dms_order_uuid',
            'meta_value' => $order_uuid,
            'return' => 'objects'
        ));
        if (!empty($existing)) {
            $existing_order = $existing[0];
            $token = function_exists('dms_invoice_issue_token') ? dms_invoice_issue_token($existing_order->get_id(), 1800) : '';
            $invoice_url = ($token && function_exists('dms_invoice_get_download_url'))
                ? dms_invoice_get_download_url($existing_order->get_id(), $token)
                : '';
            $existing_sham_cash = null;
            if ($existing_order->get_payment_method() === 'instant_barcode') {
                $existing_account = sanitize_text_field($existing_order->get_meta('_sham_cash_account'));
                $existing_company = sanitize_text_field($existing_order->get_meta('_sham_cash_company'));
                $existing_amount = floatval($existing_order->get_meta('_sham_cash_amount'));
                $existing_expiry = intval($existing_order->get_meta('_sham_cash_expiry'));
                $existing_status = sanitize_text_field($existing_order->get_meta('_sham_cash_status'));
                $existing_qr_text = sanitize_text_field($existing_order->get_meta('_sham_cash_qr_text'));
                if ($existing_qr_text === '') {
                    $existing_qr_text = $existing_account;
                }
                if ($existing_amount <= 0) {
                    $existing_amount = floatval($existing_order->get_total());
                }
                if ($existing_expiry <= 0) {
                    $existing_expiry = time() + (15 * 60);
                }
                if ($existing_status === '') {
                    $existing_status = 'pending';
                }
                $existing_time_limit = max(1, intval(($existing_expiry - time()) / 60));
                $existing_qr_url = 'https://api.qrserver.com/v1/create-qr-code/?size=200x200&data='
                    . rawurlencode($existing_qr_text)
                    . '&color=dc2626&bgcolor=ffffff';

                $existing_sham_cash = array(
                    'company' => $existing_company,
                    'account' => $existing_account,
                    'amount' => $existing_amount,
                    'expiry' => $existing_expiry,
                    'time_limit' => $existing_time_limit,
                    'currency' => strtolower($existing_order->get_currency()),
                    'qr_text' => $existing_qr_text,
                    'qr_url' => $existing_qr_url,
                    'status' => $existing_status,
                    'confirmation_endpoint' => rest_url('dms/v1/orders/' . $existing_order->get_id() . '/sham-cash-confirm')
                );
            }
            return array(
                'id' => $existing_order->get_id(),
                'order_number' => $existing_order->get_order_number(),
                'status' => $existing_order->get_status(),
                'total' => $existing_order->get_total(),
                'currency' => strtolower($existing_order->get_currency()),
                'message' => 'Order already created',
                'invoice_url' => $invoice_url,
                'sham_cash' => $existing_sham_cash
            );
        }
    }
    
    $line_items = $params['line_items'];
    $billing = is_array($params['billing'] ?? null) ? $params['billing'] : array();
    $shipping = is_array($params['shipping'] ?? null) ? $params['shipping'] : array();
    $payment_method = sanitize_text_field($params['payment_method'] ?? 'cod');
    $notes = sanitize_textarea_field($params['customer_note'] ?? '');
    
    // Verify customer exists
    $customer = get_userdata($customer_id);
    if (!$customer) {
        dms_ecom_log('error', 'Customer not found', array('customer_id' => $customer_id));
        return new WP_Error('customer_not_found', 'Customer not found', array('status' => 404));
    }
    
    // Create order
    try {
        $order = wc_create_order();
    } catch (Exception $create_error) {
        dms_ecom_log('error', 'Failed to create WC_Order: ' . $create_error->getMessage());
        return new WP_Error('order_creation_failed', 'تعذر إنشاء الطلب حالياً، يرجى المحاولة لاحقاً.', array('status' => 500));
    }
    
    if (is_wp_error($order)) {
        return new WP_Error('order_creation_failed', 'Could not create order', array('status' => 500));
    }
    
    // Set customer
    $order->set_customer_id($customer_id);
    
    // Set currency with validation and fallback
    if (!empty($params['currency'])) {
        $currency_code = sanitize_text_field(strtoupper($params['currency']));
        try {
            // Try to set the currency
            $order->set_currency($currency_code);
        } catch (Exception $currency_error) {
            dms_ecom_log('warning', 'Invalid currency code, using shop default', array(
                'requested_currency' => $currency_code,
                'error' => $currency_error->getMessage()
            ));
            // Don't fail the order, just use shop default currency
            // Order will use get_woocommerce_currency() by default
        }
    }
    
    $items_added = 0;
    
    // Add line items with unit metadata
    foreach ($line_items as $item) {
        if (!is_array($item)) {
            dms_ecom_log('warning', 'Skipping non-array line item');
            continue;
        }
        
        $product_id = intval($item['product_id'] ?? 0);
        $quantity = max(1, intval($item['quantity'] ?? 1));
        $variation_id = intval($item['variation_id'] ?? ($item['variationId'] ?? 0));
        $attributes = is_array($item['attributes'] ?? null) ? $item['attributes'] : array();
        
        if ($product_id <= 0) {
            dms_ecom_log('warning', 'Skipping item with invalid product_id', array('product_id' => $product_id));
            continue;
        }
        
        try {
            $product = wc_get_product($product_id);
            if (!$product) {
                dms_ecom_log('warning', 'Product not found', array('product_id' => $product_id));
                continue;  // Skip invalid products instead of failing entire order
            }
            if ($variation_id > 0) {
                $variation_product = wc_get_product($variation_id);
                if ($variation_product && $variation_product->get_parent_id() === $product_id) {
                    $product = $variation_product;
                } else {
                    $variation_id = 0;
                }
            }
        } catch (Exception $product_error) {
            dms_ecom_log('warning', 'Error loading product ' . $product_id, array(
                'error' => $product_error->getMessage()
            ));
            continue;
        }
        // Normalize meta_data (if the client sent unit info inside meta_data)
        $meta_lookup = array();
        if (!empty($item['meta_data']) && is_array($item['meta_data'])) {
            foreach ($item['meta_data'] as $meta_entry) {
                if (isset($meta_entry['key']) && array_key_exists('value', $meta_entry)) {
                    $meta_lookup[$meta_entry['key']] = $meta_entry['value'];
                }
            }
        }
        
        $unit_type = sanitize_text_field($item['unit_type'] ?? ($item['dms_unit_type'] ?? ($meta_lookup['unit_type'] ?? 'piece')));
        if (empty($unit_type)) {
            $unit_type = 'piece';
        }
        
        $default_unit_name = ($unit_type === 'package') ? 'طرد' : 'قطعة';
        $unit_name = sanitize_text_field(
            $item['unit_name']
            ?? ($item['dms_unit_name'] ?? ($meta_lookup['unit_name'] ?? $default_unit_name))
        );
        
        $unit_pieces = absint(
            $item['unit_pieces']
            ?? ($item['dms_unit_pieces_count'] ?? ($meta_lookup['unit_pieces'] ?? ($meta_lookup['pieces_count'] ?? 0)))
        );
        if ($unit_pieces <= 0) {
            $unit_pieces = 1;
        }
        
        $unit_price = null;
        if (isset($item['unit_price'])) {
            $unit_price = floatval($item['unit_price']);
        } elseif (isset($item['dms_calculated_unit_price'])) {
            $unit_price = floatval($item['dms_calculated_unit_price']);
        } elseif (isset($meta_lookup['unit_price'])) {
            $unit_price = floatval($meta_lookup['unit_price']);
        }
        
        if ($unit_price === null || $unit_price <= 0) {
            $unit_price = floatval($product->get_price());
        }
        
        /**
         * If the incoming unit_price looks like a per-piece price but the user selected
         * a multi-piece unit (box/package), scale it up so totals reflect the selected unit.
         * This prevents "package" showing piece price.
         */
        $unit_price_final = $unit_price;
        if ($unit_type !== 'piece' && $unit_pieces > 1) {
            $piece_price = floatval($product->get_price());
            // If provided unit price is suspiciously low compared to single piece, assume it's per piece
            if ($unit_price_final <= ($piece_price * 1.01)) {
                $unit_price_final = $unit_price_final * $unit_pieces;
            }
        }
        
        $line_total = round($unit_price_final * $quantity, wc_get_price_decimals());
        
        try {
            $order_item = new WC_Order_Item_Product();
            $order_item->set_product($product);
            $order_item->set_quantity($quantity);
            $order_item->set_subtotal($line_total);
            $order_item->set_total($line_total);
            if ($variation_id > 0) {
                $order_item->set_variation_id($variation_id);
            }
            if (!empty($attributes) && is_array($attributes)) {
                foreach ($attributes as $attr_key => $attr_value) {
                    $order_item->add_meta_data('attribute_' . wc_clean($attr_key), sanitize_text_field($attr_value), true);
                }
            }
            
            // Persist unit metadata (new keys + legacy keys for backward compatibility)
            $order_item->add_meta_data('unit_type', $unit_type, true);
            $order_item->add_meta_data('unit_name', $unit_name, true);
            $order_item->add_meta_data('unit_pieces', $unit_pieces, true);
            $order_item->add_meta_data('unit_price', $unit_price_final, true);
            $order_item->add_meta_data('dms_unit_type', $unit_type, true);
            $order_item->add_meta_data('dms_unit_name', $unit_name, true);
            $order_item->add_meta_data('dms_unit_pieces_count', $unit_pieces, true);
            $order_item->add_meta_data('dms_calculated_unit_price', $unit_price_final, true);
            
            $order->add_item($order_item);
            $items_added++;
        } catch (Exception $item_error) {
            dms_ecom_log('warning', 'Error creating order item for product ' . $product_id, array(
                'error' => $item_error->getMessage(),
                'quantity' => $quantity,
                'line_total' => $line_total
            ));
            continue;  // Skip this item but continue with others
        }
    }
    
    if ($items_added === 0) {
        $order->delete(true);
        return new WP_Error('invalid_items', 'No valid products were provided', array('status' => 400));
    }
    
    // Set billing address
    if (!empty($billing)) {
        $order->set_billing_first_name(sanitize_text_field($billing['first_name'] ?? ''));
        $order->set_billing_last_name(sanitize_text_field($billing['last_name'] ?? ''));
        $order->set_billing_phone(sanitize_text_field($billing['phone'] ?? ''));
        
        // Safe email retrieval with fallback
        if (!empty($billing['email'])) {
            $billing_email = sanitize_email($billing['email']);
        } elseif ($customer && isset($customer->user_email)) {
            $billing_email = sanitize_email($customer->user_email);
        } else {
            $billing_email = '';
            dms_ecom_log('warning', 'No email found for billing address');
        }
        
        if ($billing_email) {
            $order->set_billing_email($billing_email);
        }
        $order->set_billing_address_1(sanitize_text_field($billing['address_1'] ?? ''));
        $order->set_billing_address_2(sanitize_text_field($billing['address_2'] ?? ''));
        $order->set_billing_city(sanitize_text_field($billing['city'] ?? ''));
        $order->set_billing_state(sanitize_text_field($billing['state'] ?? ''));
        $order->set_billing_company(sanitize_text_field($billing['company'] ?? ''));
    }
    
    // Shipping falls back to billing when not provided
    $shipping_data = !empty($shipping) ? $shipping : $billing;
    if (!empty($shipping_data)) {
        $order->set_shipping_first_name(sanitize_text_field($shipping_data['first_name'] ?? ''));
        $order->set_shipping_last_name(sanitize_text_field($shipping_data['last_name'] ?? ''));
        $order->set_shipping_company(sanitize_text_field($shipping_data['company'] ?? ''));
        $order->set_shipping_address_1(sanitize_text_field($shipping_data['address_1'] ?? ''));
        $order->set_shipping_address_2(sanitize_text_field($shipping_data['address_2'] ?? ''));
        $order->set_shipping_city(sanitize_text_field($shipping_data['city'] ?? ''));
        $order->set_shipping_state(sanitize_text_field($shipping_data['state'] ?? ''));
        if (!empty($shipping_data['phone'])) {
            $order->add_meta_data('shipping_phone', sanitize_text_field($shipping_data['phone']), true);
        }
    }
    
    // Set payment method
    $order->set_payment_method($payment_method);
    
    // Get payment method title from request or use default
    $payment_method_title = sanitize_text_field($params['payment_method_title'] ?? '');
    if (empty($payment_method_title)) {
        // Default titles based on payment method
        switch ($payment_method) {
            case 'cod':
                $payment_method_title = 'الدفع عند الاستلام';
                break;
            case 'bacs':
                $payment_method_title = 'حوالة مصرفية';
                break;
            case 'instant_barcode':
                $payment_method_title = 'شام كاش - الباركود الفوري';
                break;
            default:
                $payment_method_title = 'Online Payment';
                break;
        }
    }
    $order->set_payment_method_title($payment_method_title);

    // Meta data
    $order->add_meta_data('dms_order_source', 'app', true);
    if (!empty($order_uuid)) {
        $order->add_meta_data('dms_order_uuid', $order_uuid, true);
    }
    if (!empty($order_meta['dms_price_group'])) {
        $order->add_meta_data('dms_price_group', sanitize_text_field($order_meta['dms_price_group']), true);
    }
    if (!empty($order_meta['dms_currency'])) {
        $order->add_meta_data('dms_currency', sanitize_text_field($order_meta['dms_currency']), true);
    }
    $meta_keys_to_copy = array(
        'order_contact_name',
        'order_phone',
        'order_address',
        'order_city',
        'order_state',
        'order_company'
    );
    foreach ($meta_keys_to_copy as $m_key) {
        if (!empty($order_meta[$m_key])) {
            $order->add_meta_data($m_key, sanitize_text_field($order_meta[$m_key]), true);
        }
    }
    
    // Add notes
    if (!empty($notes)) {
        $order->add_order_note($notes);
    }
    
    // Calculate totals and save
    try {
        $order->calculate_totals();
    } catch (Exception $calc_error) {
        dms_ecom_log('warning', 'Error calculating order totals: ' . $calc_error->getMessage());
        // Continue anyway - this is not critical
    }

    // Apply Sham Cash metadata after totals are calculated (ensures correct amount)
    $sham_cash_payload = null;
    if ($payment_method === 'instant_barcode') {
        $sham_cash_config = function_exists('dms_get_sham_cash_config')
            ? dms_get_sham_cash_config()
            : array();
        $time_limit = intval($sham_cash_config['time_limit'] ?? 15);
        if ($time_limit <= 0) {
            $time_limit = 15;
        }
        $account_code = sanitize_text_field($sham_cash_config['account_code'] ?? '2f3b91dd0befb9f619ef06697e7a1dc8');
        $company_name = sanitize_text_field($sham_cash_config['company_name'] ?? 'لبكو المحدودة المسؤولية');
        if ($account_code === '') {
            $account_code = '2f3b91dd0befb9f619ef06697e7a1dc8';
        }
        if ($company_name === '') {
            $company_name = 'لبكو المحدودة المسؤولية';
        }
        $order_total = floatval($order->get_total());
        $expiry_time = time() + ($time_limit * 60);
        $order_currency = strtolower($order->get_currency());
        $qr_text = $account_code;
        $qr_url = 'https://api.qrserver.com/v1/create-qr-code/?size=200x200&data='
            . rawurlencode($qr_text)
            . '&color=dc2626&bgcolor=ffffff';

        $order->update_meta_data('_sham_cash_method', 'barcode_transfer');
        $order->update_meta_data('_sham_cash_account', $account_code);
        $order->update_meta_data('_sham_cash_company', $company_name);
        $order->update_meta_data('_sham_cash_amount', $order_total);
        $order->update_meta_data('_sham_cash_expiry', $expiry_time);
        $order->update_meta_data('_sham_cash_status', 'pending');
        $order->update_meta_data('_sham_cash_qr_text', $qr_text);

        $order->set_status('pending');
        $order->add_order_note(sprintf(
            'تم اختيار الدفع عبر شام كاش - الباركود الفوري. رقم الحساب: %s. المبلغ: %s. المهلة: %s دقيقة.',
            $account_code,
            wc_price($order_total),
            $time_limit
        ));

        $sham_cash_payload = array(
            'company' => $company_name,
            'account' => $account_code,
            'amount' => $order_total,
            'expiry' => $expiry_time,
            'time_limit' => $time_limit,
            'currency' => $order_currency,
            'qr_text' => $qr_text,
            'qr_url' => $qr_url,
            'status' => 'pending',
            'confirmation_endpoint' => rest_url('dms/v1/orders/' . $order->get_id() . '/sham-cash-confirm')
        );
    }
    
    try {
        $save_result = $order->save();
        
        // Check if save failed
        if (is_wp_error($save_result)) {
            return new WP_Error('order_save_failed', 'تعذر حفظ الطلب حالياً، يرجى المحاولة لاحقاً.', array('status' => 500));
        }
    } catch (Exception $save_error) {
        dms_ecom_log('error', 'Order save exception: ' . $save_error->getMessage());
        return new WP_Error('order_save_exception', 'تعذر حفظ الطلب حالياً، يرجى المحاولة لاحقاً.', array('status' => 500));
    }

    $invoice_token = function_exists('dms_invoice_issue_token') ? dms_invoice_issue_token($order->get_id(), 1800) : '';
    $invoice_url = ($invoice_token && function_exists('dms_invoice_get_download_url'))
        ? dms_invoice_get_download_url($order->get_id(), $invoice_token)
        : '';
    
    dms_ecom_log('info', 'Order created via API', array('order_id' => $order->get_id(), 'customer_id' => $customer_id));
    if (function_exists('dms_ecom_notify_admin_new_order')) {
        dms_ecom_notify_admin_new_order($order);
    }
    
    return array(
        'id' => $order->get_id(),
        'order_number' => $order->get_order_number(),
        'status' => $order->get_status(),
        'total' => $order->get_total(),
        'currency' => strtolower($order->get_currency()),
        'message' => 'Order created successfully',
        'invoice_url' => $invoice_url,
        'sham_cash' => $sham_cash_payload
    );
    
    } catch (Exception $e) {
        // Catch any PHP errors and return as proper JSON error
        $error_details = array(
            'message' => $e->getMessage(),
            'code' => $e->getCode(),
            'file' => $e->getFile(),
            'line' => $e->getLine(),
            'trace' => $e->getTraceAsString()
        );
        
        dms_ecom_log('error', 'Order creation exception', $error_details);
        
        // Also log to WordPress debug log for visibility
        if (defined('WP_DEBUG_LOG') && WP_DEBUG_LOG) {
            error_log('DMS Order Creation Error: ' . json_encode($error_details));
        }
        
        return new WP_Error(
            'order_creation_exception',
            'تعذر إنشاء الطلب حالياً، يرجى المحاولة لاحقاً.',
            array('status' => 500)
        );
    }
}

function dms_confirm_sham_cash_transfer($request) {
    $order_id = intval($request['id'] ?? 0);
    if ($order_id <= 0) {
        return new WP_Error('invalid_order_id', 'Invalid order id.', array('status' => 400));
    }

    $order = wc_get_order($order_id);
    if (!$order) {
        return new WP_Error('order_not_found', 'Order not found.', array('status' => 404));
    }

    $current_user_id = get_current_user_id();
    $order_customer_id = intval($order->get_customer_id());
    if (
        $current_user_id &&
        $order_customer_id &&
        $current_user_id !== $order_customer_id &&
        !current_user_can('manage_woocommerce')
    ) {
        return new WP_Error('forbidden_order', 'You cannot update this order.', array('status' => 403));
    }

    if ($order->get_payment_method() !== 'instant_barcode') {
        return new WP_Error('invalid_payment_method', 'This order is not a Sham Cash order.', array('status' => 400));
    }

    $params = $request->get_json_params();
    if (!is_array($params)) {
        $params = array();
    }

    $transaction_id = sanitize_text_field($params['transaction_id'] ?? '');
    $proof_image_url = esc_url_raw($params['proof_image_url'] ?? '');

    if ($transaction_id === '') {
        $transaction_id = 'APP-' . $order_id . '-' . time();
    }

    $order->update_meta_data('_transaction_id', $transaction_id);
    if ($proof_image_url !== '') {
        $order->update_meta_data('_payment_proof_url', $proof_image_url);
    }
    $order->update_meta_data('_sham_cash_status', 'awaiting_review');

    if (in_array($order->get_status(), array('pending', 'failed'), true)) {
        $order->set_status('on-hold');
    }

    $order->add_order_note(sprintf(
        'Sham Cash transfer confirmation submitted from app. Transaction ID: %s%s',
        $transaction_id,
        $proof_image_url !== '' ? ' | Proof: ' . $proof_image_url : ''
    ));
    $order->save();

    return array(
        'success' => true,
        'order_id' => $order->get_id(),
        'status' => $order->get_status(),
        'transaction_id' => $transaction_id,
        'proof_image_url' => $proof_image_url,
        'message' => 'Transfer confirmation submitted successfully.'
    );
}
