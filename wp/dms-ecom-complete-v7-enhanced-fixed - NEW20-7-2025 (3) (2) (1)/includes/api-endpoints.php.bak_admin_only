    if (!array_key_exists($term_id, $term_meta_cache)) {
        $all_meta = get_term_meta($term_id);
        $term_meta_cache[$term_id] = is_array($all_meta) ? $all_meta : array();
    }

    return $term_meta_cache[$term_id];
}

