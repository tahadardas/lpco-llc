/**
 * قراءة ترويسة Authorization بصيغة Bearer
 */
function dms_get_auth_header() {
    $auth_header = '';
    
    if (isset($_SERVER['HTTP_AUTHORIZATION'])) {
        $auth_header = trim($_SERVER['HTTP_AUTHORIZATION']);
    } elseif (isset($_SERVER['REDIRECT_HTTP_AUTHORIZATION'])) {
        $auth_header = trim($_SERVER['REDIRECT_HTTP_AUTHORIZATION']);
    } elseif (function_exists('apache_request_headers')) {
        $headers = apache_request_headers();
        if (isset($headers['Authorization'])) {
            $auth_header = trim($headers['Authorization']);
        }
    }
    
    return $auth_header;
}

/**
 * فك ترميز base64url
 */
function dms_base64url_decode($data) {
    $remainder = strlen($data) % 4;
    if ($remainder) {
        $padlen = 4 - $remainder;
        $data .= str_repeat('=', $padlen);
    }
    return base64_decode(strtr($data, '-_', '+/'));
}

/**
 * Structured debug logging gated behind DMS_ECOM_DEBUG
 */
function dms_ecom_log($level, $message, $context = array()) {
    if (!defined('DMS_ECOM_DEBUG') || DMS_ECOM_DEBUG !== true) {
        return;
    }
    
    if (!empty($context) && is_array($context)) {
        $message .= ' | ' . wp_json_encode($context);
    }
    
    error_log(sprintf('DMS-Ecom [%s] %s', strtoupper($level), $message));
}

/**
 * Send an admin email notification safely.
 */
function dms_ecom_send_admin_email($subject, $message) {
    $admin_email = get_option('admin_email');
    if (!is_email($admin_email)) {
        return false;
    }
    return wp_mail($admin_email, $subject, $message);
}

/**
 * Notify admin about new app user registration.
 */
function dms_ecom_notify_admin_new_user($user_id, $extra = array()) {
    $user = get_userdata($user_id);
    if (!$user) {
        return false;
    }
    $site_name = wp_specialchars_decode(get_bloginfo('name'), ENT_QUOTES);
    $subject = sprintf('[%s] مستخدم جديد عبر التطبيق', $site_name);
    $display_name = $user->display_name ?: trim($user->first_name . ' ' . $user->last_name);
    $phone = $extra['phone'] ?? get_user_meta($user_id, 'billing_phone', true);
    $company = $extra['company'] ?? get_user_meta($user_id, 'billing_company', true);
    $governorate = $extra['governorate'] ?? get_user_meta($user_id, 'billing_state', true);

    $lines = array(
        'تم تسجيل مستخدم جديد عبر التطبيق.',
        '',
        'الاسم: ' . ($display_name ?: $user->user_login),
        'اسم المستخدم: ' . $user->user_login,
        'البريد: ' . $user->user_email,
        'الهاتف: ' . ($phone ?: '-'),
        'الاسم التجاري: ' . ($company ?: '-'),
        'المحافظة: ' . ($governorate ?: '-'),
        'معرّف المستخدم: ' . $user_id
    );

    return dms_ecom_send_admin_email($subject, implode("\n", $lines));
}

/**
 * Notify admin about new app order creation.
 */
function dms_ecom_notify_admin_new_order($order) {
    if (!$order instanceof WC_Order) {
        $order = wc_get_order($order);
    }
    if (!$order) {
        return false;
    }
    $site_name = wp_specialchars_decode(get_bloginfo('name'), ENT_QUOTES);
    $subject = sprintf('[%s] طلب جديد عبر التطبيق #%s', $site_name, $order->get_order_number());

    $customer_name = trim($order->get_billing_first_name() . ' ' . $order->get_billing_last_name());
    if ($customer_name === '') {
        $customer_name = $order->get_formatted_billing_full_name();
    }
    $total = $order->get_total() . ' ' . $order->get_currency();

    $lines = array(
        'تم إنشاء طلب جديد عبر التطبيق.',
        '',
        'رقم الطلب: ' . $order->get_order_number(),
        'الإجمالي: ' . $total,
        'العميل: ' . ($customer_name ?: '-'),
        'الهاتف: ' . ($order->get_billing_phone() ?: '-'),
        'البريد: ' . ($order->get_billing_email() ?: '-'),
        'العنوان: ' . trim($order->get_billing_address_1() . ' ' . $order->get_billing_city())
    );

    $items = $order->get_items();
    if (!empty($items)) {
        $currency = $order->get_currency();
        $lines[] = '';
        $lines[] = 'تفاصيل المنتجات:';
        $index = 1;
        foreach ($items as $item) {
            if (!$item instanceof WC_Order_Item_Product) {
                continue;
            }
            $product = $item->get_product();
            $sku = $product ? $product->get_sku() : '';
            $quantity = $item->get_quantity();
            $variation_id = $item->get_variation_id();
            $unit_type = $item->get_meta('unit_type', true);
            if ($unit_type === '') {
                $unit_type = $item->get_meta('dms_unit_type', true);
            }
            $unit_name = $item->get_meta('unit_name', true);
            if ($unit_name === '') {
                $unit_name = $item->get_meta('dms_unit_name', true);
            }
            if ($unit_name === '') {
                $unit_name = ($unit_type === 'package') ? 'طرد' : 'قطعة';
            }
            $unit_pieces = $item->get_meta('unit_pieces', true);
            if ($unit_pieces === '') {
                $unit_pieces = $item->get_meta('dms_unit_pieces_count', true);
            }
            $unit_price = $item->get_meta('unit_price', true);
            if ($unit_price === '') {
                $unit_price = $item->get_meta('dms_calculated_unit_price', true);
            }
            $unit_price = is_numeric($unit_price) ? floatval($unit_price) : 0;
            if ($unit_price <= 0 && $quantity > 0) {
                $unit_price = floatval($item->get_total()) / max(1, $quantity);
            }
            $color_name = $item->get_meta('color_name', true);
            $color_slug = $item->get_meta('color_slug', true);
            $color_label = $color_name ?: $color_slug;
            $attributes = array();
            foreach ($item->get_meta_data() as $meta) {
                if (!is_object($meta)) {
                    continue;
                }
                $meta_key = isset($meta->key) ? (string) $meta->key : '';
                if ($meta_key !== '' && strpos($meta_key, 'attribute_') === 0) {
                    $label = str_replace('attribute_', '', $meta_key);
                    $attributes[] = $label . ': ' . sanitize_text_field($meta->value);
                }
            }
            $attrs_text = !empty($attributes) ? implode(' | ', $attributes) : '';
            $line_total = $item->get_total();

            $lines[] = sprintf(
                '%d) %s%s',
                $index,
                $item->get_name(),
                $sku ? ' (SKU: ' . $sku . ')' : ''
            );
            $lines[] = '   الكمية: ' . $quantity;
            $lines[] = '   الوحدة: ' . $unit_name . ($unit_type ? ' (' . $unit_type . ')' : '');
            if ($unit_pieces !== '') {
                $lines[] = '   عدد القطع: ' . $unit_pieces;
            }
            if ($unit_price > 0) {
                $lines[] = '   سعر الوحدة: ' . wc_format_decimal($unit_price) . ' ' . $currency;
            }
            if (!is_null($line_total) && $line_total !== '') {
                $lines[] = '   الإجمالي: ' . wc_format_decimal($line_total) . ' ' . $currency;
            }
            if (!empty($color_label)) {
                $lines[] = '   اللون: ' . $color_label;
            }
            if (!empty($variation_id)) {
                $lines[] = '   رقم التفرع: ' . $variation_id;
            }
            if ($attrs_text !== '') {
                $lines[] = '   الخصائص: ' . $attrs_text;
            }
            $lines[] = '';
            $index++;
        }
    }

    return dms_ecom_send_admin_email($subject, implode("\n", $lines));
}

/**
 * Get client IP address
 */
function dms_ecom_get_client_ip() {
    $ip_keys = array('HTTP_CLIENT_IP', 'HTTP_X_FORWARDED_FOR', 'REMOTE_ADDR');
    foreach ($ip_keys as $key) {
        if (!empty($_SERVER[$key])) {
            $raw = explode(',', $_SERVER[$key]);
            return sanitize_text_field(trim($raw[0]));
        }
    }
    return '';
}

/**
 * Simple IP-based rate limiting
 */
function dms_ecom_rate_limit($action, $ip, $limit = 5, $window = 600) {
    if (empty($ip)) {
        return true;
    }
    
    $key = 'dms_rate_' . $action . '_' . md5($ip);
    $cache_group = 'dms_api_rate_limit';
    $bucket = wp_cache_get($key, $cache_group);
    if ($bucket === false) {
        $bucket = get_transient($key);
    }
    
    if (!$bucket || !is_array($bucket)) {
        $bucket = array('count' => 0, 'start' => time());
    }
    
    $elapsed = time() - intval($bucket['start']);
    if ($elapsed >= $window) {
        $bucket = array('count' => 0, 'start' => time());
        $elapsed = 0;
    }
    
    if ($bucket['count'] >= $limit) {
        dms_ecom_log('warn', 'Rate limit hit', array('action' => $action, 'ip' => $ip));
        return new WP_Error('rate_limited', 'Too many requests, please try again later.', array('status' => 429));
    }
    
    $bucket['count']++;
    $ttl = max($window - $elapsed, 1);
    wp_cache_set($key, $bucket, $cache_group, $ttl);
    set_transient($key, $bucket, $ttl);
    
    return true;
}

/**
 * Optional CAPTCHA validation hook (Turnstile/reCAPTCHA)
 */
function dms_ecom_validate_captcha_if_required($token, $ip) {
    $settings = function_exists('dms_app_get_settings') ? dms_app_get_settings() : array();
    $has_turnstile = !empty($settings['turnstile_secret_key']);
    $has_recaptcha = !empty($settings['recaptcha_secret_key']);

    $captcha_required = apply_filters('dms_ecom_require_captcha', ($has_turnstile || $has_recaptcha));
    if (!$captcha_required) {
        return true;
    }
    
    if (empty($token)) {
        return new WP_Error('captcha_missing', 'Captcha validation is required.', array('status' => 400));
    }

    // Turnstile verification
    if ($has_turnstile) {
        $response = wp_remote_post('https://challenges.cloudflare.com/turnstile/v0/siteverify', array(
            'body' => array(
                'secret' => $settings['turnstile_secret_key'],
                'response' => $token,
                'remoteip' => $ip,
            ),
            'timeout' => 5,
        ));
        $ok = false;
        if (!is_wp_error($response) && wp_remote_retrieve_response_code($response) === 200) {
            $data = json_decode(wp_remote_retrieve_body($response), true);
            $ok = !empty($data['success']);
        }
        if (!$ok) {
            return new WP_Error('captcha_failed', 'Captcha validation failed.', array('status' => 400));
        }
        return true;
    }

    // reCAPTCHA verification
    if ($has_recaptcha) {
        $response = wp_remote_post('https://www.google.com/recaptcha/api/siteverify', array(
            'body' => array(
                'secret' => $settings['recaptcha_secret_key'],
                'response' => $token,
                'remoteip' => $ip,
            ),
            'timeout' => 5,
        ));
        $ok = false;
        if (!is_wp_error($response) && wp_remote_retrieve_response_code($response) === 200) {
            $data = json_decode(wp_remote_retrieve_body($response), true);
            $ok = !empty($data['success']);
        }
        if (!$ok) {
            return new WP_Error('captcha_failed', 'Captcha validation failed.', array('status' => 400));
        }
        return true;
    }

    return true;
}

// Ensure consistent CORS/preflight responses for DMS API
add_action('rest_api_init', function () {
    add_filter('rest_pre_serve_request', 'lpco_dms_send_cors_headers', 15, 4);
});

function lpco_dms_is_request($request) {
    if (!($request instanceof WP_REST_Request)) {
        return false;
    }
    $route = $request->get_route();
    if (!is_string($route)) {
        return false;
    }
    return strpos($route, '/dms/v1') === 0 || strpos($route, '/jwt-auth/v1') === 0;
}

function lpco_dms_is_local_origin($origin) {
    if (!is_string($origin) || $origin === '') {
        return false;
    }

    $parts = wp_parse_url($origin);
    if (!is_array($parts) || empty($parts['host'])) {
        return false;
    }

    $host = strtolower((string) $parts['host']);
    if (!in_array($host, array('localhost', '127.0.0.1', '::1', '0.0.0.0'), true)) {
        return false;
    }

    $scheme = isset($parts['scheme']) ? strtolower((string) $parts['scheme']) : 'http';
    return in_array($scheme, array('http', 'https'), true);
}

function lpco_dms_send_cors_headers($served, $result, $request, $server) {
    if (!lpco_dms_is_request($request)) {
        return $served;
    }
    if (headers_sent()) {
        return $served;
    }
    $allowed_origins = array(
        'http://localhost:8080',
        'http://localhost',
        'https://localhost',
        'ionic://localhost',
        'capacitor://localhost',
        'https://lpco-llc.com',
        'http://lpco-llc.com',
        'https://app.lpco-llc.com',
        'http://app.lpco-llc.com'
    );
    $origin = isset($_SERVER['HTTP_ORIGIN']) ? $_SERVER['HTTP_ORIGIN'] : '';
    
    $origin_allowed = false;

    // Handle WebView/file-based origin (comes as "null" string)
    if ($origin === 'null' || $origin === '') {
        header('Access-Control-Allow-Origin: *', true);
        $origin_allowed = true;
    } elseif ($origin && (in_array($origin, $allowed_origins, true) || lpco_dms_is_local_origin($origin))) {
        header('Access-Control-Allow-Origin: ' . $origin, true);
        header('Vary: Origin', true);
        header('Access-Control-Allow-Credentials: true', true);
        $origin_allowed = true;
    }
    
    header('Access-Control-Allow-Methods: GET, POST, PUT, PATCH, DELETE, OPTIONS', true);
    header('Access-Control-Allow-Headers: Authorization, Content-Type, X-WP-Nonce, X-Requested-With, X-Device-Token, X-Idempotency-Key, Accept', true);
    header('Access-Control-Max-Age: 3600', true);

    if ('OPTIONS' === $request->get_method()) {
        if (!$origin_allowed) {
            status_header(403);
            return true;
        }
        status_header(200);
        return true;
    }

    return $served;
}

// Backward compatibility alias (if referenced elsewhere)
function dms_ecom_send_cors_headers($served, $result, $request, $server) {
    return lpco_dms_send_cors_headers($served, $result, $request, $server);
}

function lpco_dms_is_guest_request($request) {
    if (!($request instanceof WP_REST_Request)) {
        return false;
    }
    $guest = $request->get_param('guest');
    $mode = $request->get_param('mode');
    if (is_string($mode) && strtolower($mode) === 'guest') {
        return true;
    }
    if ($guest === true || $guest === 1 || $guest === '1' || $guest === 'true' || $guest === 'guest') {
        return true;
    }
    return false;
}

function lpco_dms_allow_guest_or_auth($request) {
    if (lpco_dms_is_guest_request($request)) {
        return true;
    }
    return dms_validate_jwt_request($request);
}

function lpco_dms_guest_cache_key($prefix, $request) {
    return lpco_dms_build_api_cache_key($prefix, $request, 'guest', 'catalog');
}

function lpco_dms_get_api_cache_versions() {
    $versions = wp_cache_get('api_cache_versions', 'dms_api');
    if ($versions === false) {
        $versions = get_option('lpco_dms_api_cache_versions', array());
        if (!is_array($versions)) {
            $versions = array();
        }
        wp_cache_set('api_cache_versions', $versions, 'dms_api', 300);
    }
    return $versions;
}

function lpco_dms_set_api_cache_versions($versions) {
    if (!is_array($versions)) {
        $versions = array();
    }
    update_option('lpco_dms_api_cache_versions', $versions, false);
    wp_cache_set('api_cache_versions', $versions, 'dms_api', 300);
}

function lpco_dms_api_cache_version($bucket = 'catalog') {
    $bucket = sanitize_key((string) $bucket);
    $versions = lpco_dms_get_api_cache_versions();
    $version = isset($versions[$bucket]) ? (int) $versions[$bucket] : 1;
    return max(1, $version);
}

function lpco_dms_bump_api_cache_version($bucket = 'catalog') {
    $bucket = sanitize_key((string) $bucket);
    $versions = lpco_dms_get_api_cache_versions();
    $versions[$bucket] = lpco_dms_api_cache_version($bucket) + 1;
    lpco_dms_set_api_cache_versions($versions);
    return $versions[$bucket];
}

function lpco_dms_build_api_cache_key($prefix, $request, $scope = 'guest', $bucket = 'catalog') {
    if (!($request instanceof WP_REST_Request)) {
        return '';
    }

    $params = $request->get_params();
    if (!is_array($params)) {
        $params = array();
    }
    unset($params['token'], $params['jwt'], $params['authorization'], $params['access_token']);
    ksort($params);

    $bucket = sanitize_key((string) $bucket);
    $scope = sanitize_key((string) $scope);

    return sprintf(
        'lpco_dms_%s_v%d_%s_%s',
        $bucket,
        lpco_dms_api_cache_version($bucket),
        sanitize_key((string) $prefix),
        $scope . '_' . md5(wp_json_encode($params))
    );
}

function lpco_dms_auth_cache_key($prefix, $request, $user_id, $group, $currency) {
    $scope = sprintf(
        'user_%d_%s_%s',
        absint($user_id),
        sanitize_key((string) $group),
        sanitize_key((string) $currency)
    );

    return lpco_dms_build_api_cache_key($prefix, $request, $scope, 'catalog');
}

function lpco_dms_api_cache_get($cache_key, $cache_group = 'dms_api') {
    if (!$cache_key) {
        return false;
    }

    $cached = wp_cache_get($cache_key, $cache_group);
    if ($cached !== false) {
        return $cached;
    }

    return get_transient($cache_key);
}

function lpco_dms_api_cache_set($cache_key, $value, $ttl = 300, $cache_group = 'dms_api') {
    if (!$cache_key) {
        return;
    }

    wp_cache_set($cache_key, $value, $cache_group, $ttl);
    set_transient($cache_key, $value, $ttl);
}

function lpco_dms_guest_cache_get($cache_key) {
    return lpco_dms_api_cache_get($cache_key, 'dms_api');
}

function lpco_dms_guest_cache_set($cache_key, $value) {
    lpco_dms_api_cache_set($cache_key, $value, 300, 'dms_api');
}

function lpco_dms_auth_cache_get($cache_key) {
    return lpco_dms_api_cache_get($cache_key, 'dms_api');
}

function lpco_dms_auth_cache_set($cache_key, $value) {
    lpco_dms_api_cache_set($cache_key, $value, 120, 'dms_api');
}

function lpco_dms_flush_catalog_api_cache() {
    lpco_dms_bump_api_cache_version('catalog');
}

